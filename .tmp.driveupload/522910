function bindCadastroPdf() {
  const zone  = document.getElementById('cadDropZone');
  const input = document.getElementById('cadPdfInput');
  if (!zone||!input) return;
  zone.addEventListener('dragover', e=>{ e.preventDefault(); zone.classList.add('drag-over'); });
  zone.addEventListener('dragleave', ()=>zone.classList.remove('drag-over'));
  zone.addEventListener('drop', e=>{
    e.preventDefault(); zone.classList.remove('drag-over');
    const files = e.dataTransfer?.files;
    if (files?.length) processarPdf(files[0]);
  });
  input.addEventListener('change', function(){ if (this.files?.length) processarPdf(this.files[0]); });
  document.addEventListener('paste', function(e) {
    if (CURRENT_TAB!=='cadastro'||CURRENT_METHOD!=='pdf') return;
    for (const item of (e.clipboardData?.items||[])) {
      if (item.type.startsWith('image/')) { const f=item.getAsFile(); if(f) processarPdf(f); }
    }
  });
}

