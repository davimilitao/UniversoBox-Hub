  const nome  = (document.getElementById('cNome')?.value||'').trim();
  const marca = (document.getElementById('cMarca')?.value||'').trim();
  if (!sku||!nome||!marca) { alert('SKU, Nome e Marca são obrigatórios.'); return; }
  const produto = {
    sku, name:nome, marca,
    ean:     document.getElementById('cEan')?.value.trim()||'',
    eanBox:  document.getElementById('cEanBox')?.value.trim()||'',
    weight:  parseFloat(document.getElementById('cPeso')?.value)||null,
    width:   parseFloat(document.getElementById('cLarg')?.value)||null,
    height:  parseFloat(document.getElementById('cAlt')?.value)||null,
    depth:   parseFloat(document.getElementById('cProf')?.value)||null,
    tagsRaw: document.getElementById('cTags')?.value.trim()||'',
    situacao:'Ativo', stock:0,
  };
  const btn = document.getElementById('cadSaveBtn');
  if (btn) { btn.disabled=true; btn.textContent='Salvando…'; }
  try {
    await api('/products/manual',{method:'POST',body:JSON.stringify(produto)});
    ALL.unshift(parseTags(produto));
    buildBrandBar(); buildFilterPanel(); filter(); updateIncompletos();
    alert(`Produto ${sku} cadastrado!`);
    renderCadastroMethod('pdf');
  } catch(e) {
    ALL.unshift(parseTags(produto));
    buildBrandBar(); buildFilterPanel(); filter(); updateIncompletos();
    alert(`Adicionado localmente.\nAdicione a rota POST /products/manual no server.js para persistir.`);
    renderCadastroMethod('pdf');
  } finally { if(btn){btn.disabled=false;} }
}

/* ══ MODAL JUST ══ */
let _justCb=null;
function openJust(titulo, label, callback, danger=false) {
  _justCb=callback;
  document.getElementById('justTitulo').textContent=titulo;
  document.getElementById('justLabel').textContent=label;
  document.getElementById('justTexto').value='';
  document.getElementById('justConfirmar').className=`btn ${danger?'btn-danger':'btn-primary'}`;
  document.getElementById('modalJust').classList.remove('hidden');
}
['modalJustClose','modalJustBd','justCancelar'].forEach(id=>{
  document.getElementById(id).addEventListener('click',()=>{
    document.getElementById('modalJust').classList.add('hidden'); _justCb=null;
  });
});
document.getElementById('justConfirmar').addEventListener('click',()=>{
  const txt=document.getElementById('justTexto').value.trim();
  if(_justCb) _justCb(txt);
  document.getElementById('modalJust').classList.add('hidden'); _justCb=null;
});

/* ══ NAVEGAÇÃO ══ */
function setTab(tab) {
  CURRENT_TAB=tab;
  const panes={catalogo:'pane-catalogo',studio:'pane-studio',cadastro:'pane-cadastro'};
  Object.entries(panes).forEach(([id,pid])=>{
    const el=document.getElementById(pid);
    if(el) el.style.display=id===tab?'':none_for(id);
    document.querySelector(`.ps-tab[data-tab="${id}"]`)?.classList.toggle('active',id===tab);
  });
  document.querySelectorAll('.ps-mob-tab[data-tab]').forEach(btn=>{
    btn.classList.toggle('active',btn.dataset.tab===tab);
  });
  if(tab==='cadastro') renderCadastroMethod(CURRENT_METHOD);
}
function none_for(id) {
  // studio e cadastro usam flex
  return id==='catalogo' ? 'none' : 'none';
}

// Inicializar panes corretamente
function initPanes() {
  document.getElementById('pane-catalogo').style.display='';
  document.getElementById('pane-studio').style.display='none';
  document.getElementById('pane-cadastro').style.display='none';
}

document.querySelectorAll('.ps-tab[data-tab], .ps-mob-tab[data-tab]').forEach(btn=>{
  btn.addEventListener('click',()=>setTab(btn.dataset.tab));
});
document.querySelectorAll('.cad-m[data-method]').forEach(el=>{
  el.addEventListener('click',()=>renderCadastroMethod(el.dataset.method));
});

// Atalhos incompletos
document.getElementById('incSemFoto').addEventListener('click',()=>{ ACTIVE.alerta.add('foto'); setTab('catalogo'); filter(); });
document.getElementById('incSemDims').addEventListener('click',()=>{ ACTIVE.alerta.add('dims'); setTab('catalogo'); filter(); });
document.getElementById('incSemEan').addEventListener('click',()=>{ ACTIVE.alerta.add('ean');  setTab('catalogo'); filter(); });

// Filtros toggle
document.getElementById('filterToggle').addEventListener('click',()=>{
  const p=document.getElementById('filterPanel');
  const t=document.getElementById('filterToggle');
  const open=p.classList.toggle('open');
  t.classList.toggle('open',open);
});

// Busca
document.getElementById('searchQ').addEventListener('input',function(){
  document.getElementById('searchClear').style.display=this.value?'block':'none';
  filter();
});
document.getElementById('searchClear').addEventListener('click',()=>{
  document.getElementById('searchQ').value='';
  document.getElementById('searchClear').style.display='none';
  filter();
});

// Grade/Lista
document.getElementById('vbGrid').addEventListener('click',()=>{
  VIEW='grid';
  document.getElementById('vbGrid').classList.add('on');
  document.getElementById('vbList').classList.remove('on');
  render();
});
document.getElementById('vbList').addEventListener('click',()=>{
  VIEW='list';
  document.getElementById('vbList').classList.add('on');
  document.getElementById('vbGrid').classList.remove('on');
  render();
});

// Limpar filtros (mobile)
document.getElementById('mobClearBtn').addEventListener('click',()=>{
  Object.values(ACTIVE).forEach(s=>s.clear());
  document.querySelectorAll('.fp-item.active,.fp-alert.active,.brand-chip.active').forEach(el=>el.classList.remove('active'));
  document.getElementById('searchQ').value='';
  document.getElementById('searchClear').style.display='none';
  filter();
});

// ESC
document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){
    document.getElementById('modalProd').classList.add('hidden');
    document.getElementById('modalJust').classList.add('hidden');
  }
});

// URL params
function handleUrlParams() {
  const sku=new URLSearchParams(window.location.search).get('sku');
  if(sku){const found=ALL.find(p=>p.sku===sku);if(found){openStudio(found);setTab('studio');}}
}

/* ══ INIT ══ */
initPanes();
boot().then(()=>handleUrlParams());
</script>
