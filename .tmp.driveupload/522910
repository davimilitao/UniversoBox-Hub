<script>
'use strict';
/* ══ UTILS ══ */
const TK = 'expedicao_pro_terminal_id';
function tid() { let i=localStorage.getItem(TK); if(!i){i=crypto.randomUUID();localStorage.setItem(TK,i);} return i; }

async function api(path, opts={}) {
  const token = localStorage.getItem('expedicao_token')||'';
  const res = await fetch(path, {
    ...opts,
    headers: { 'content-type':'application/json','x-terminal-id':tid(),'authorization':`Bearer ${token}`, ...(opts.headers||{}) }
  });
  const d = await res.json().catch(()=>({}));
  if (res.status===401) { window.location.href='/login'; return null; }
  if (!res.ok) throw new Error(d.error||`HTTP ${res.status}`);
  return d;
}

function esc(s) {
  return (s??'').toString().replace(/[&<>"']/g, m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'})[m]);
}

/* ══ ESTADO ══ */
let ALL=[], EMBS=[], FILTERED=[], PAGE=48, VIEW='grid';
let ACTIVE = { marca:new Set(), modalidade:new Set(), grupo:new Set(), inteligencia:new Set(), alerta:new Set() };
let CURRENT_TAB='catalogo', CURRENT_PRODUCT=null, CURRENT_METHOD='pdf';
let SHOW_SILENCIADOS=false;
let SILENCIADOS = new Set(JSON.parse(localStorage.getItem('ps_silenciados')||'[]'));
let EXCLUIDOS   = new Set(JSON.parse(localStorage.getItem('ps_excluidos')||'[]'));
function saveSil(){ localStorage.setItem('ps_silenciados',JSON.stringify([...SILENCIADOS])); }
function saveExc(){ localStorage.setItem('ps_excluidos',  JSON.stringify([...EXCLUIDOS])); }

/* ══ PARSE ══ */
function parseTags(p) {
  const raw = p.tagsRaw||'';
  const grupos=new Set(), marcas=new Set(), mods=new Set();
  for (const block of raw.split(',')) {
    for (const part of block.split('|')) {
      const t = part.trim();
      if      (t.startsWith('Grupo:'))       grupos.add(t.slice(6).trim());
      else if (t.startsWith('Marca:'))       marcas.add(t.slice(6).trim());
      else if (t.startsWith('Modalidade:')) mods.add(t.slice(11).trim());
    }
  }
  const mc = p.marca && !p.marca.includes(':') && !p.marca.includes(';') ? p.marca : '';
  if (!marcas.size && mc) marcas.add(mc);
  return {...p, _grupos:[...grupos], _marcas:[...marcas], _mods:[...mods]};
}

/* BUG FIX: displayImage pode ser '/assets/placeholder.png' — não confiar nele */
function hasPhoto(p) {
  const ov = p.override||{};
  // Tem foto real se: stockPhotos com URL cloudinary/externa, ou images[] com URL real
  const stockOk = Array.isArray(ov.stockPhotos) && ov.stockPhotos.some(u => u && !u.includes('placeholder'));
  const imagesOk = Array.isArray(p.images) && p.images.some(u => u && !u.includes('placeholder'));
  const dispOk = p.displayImage && !p.displayImage.includes('placeholder') && !p.displayImage.includes('/assets/');
  return stockOk || imagesOk || dispOk;
}

function bestPhoto(p) {
  const ov = p.override||{};
  const sp = Array.isArray(ov.stockPhotos) ? ov.stockPhotos.find(u=>u&&!u.includes('placeholder')) : null;
  const im = Array.isArray(p.images) ? p.images.find(u=>u&&!u.includes('placeholder')) : null;
  return sp || im || null;
}

function calcScore(p) {
  let s = 0;
  if (hasPhoto(p))                         s += 25;
  if (p.ean)                               s += 20;
  if (p.width && p.height && p.depth)      s += 20;
  if (p.preco)                             s += 20;
  if (p.weight)                            s += 15;
  return s;
}
function scoreClass(s) { return s>=80?'full':s>=50?'mid':'low'; }

/* ══ BOOT ══ */
async function boot() {
  showSkeleton();
  try {
    const [pd, ed] = await Promise.all([api('/products/all'), api('/embalagens/list')]);
    if (!pd) return;
    ALL = (pd.items||[]).map(parseTags).filter(p=>!EXCLUIDOS.has(p.sku));
    EMBS = ed?.items||[];
    buildBrandBar();
    buildFilterPanel();
    updateIncompletos();
    filter();
  } catch(e) {
    document.getElementById('catalogoContent').innerHTML =
      `<div class="state-msg"><div class="icon">⚠️</div><p>Erro ao carregar: ${esc(e.message)}</p></div>`;
  }
}

/* ══ BRAND BAR — chips de marca na segunda linha ══ */
const BRAND_COLORS = {
  'Safety 1st':'#3b82f6','Maxi-Cosi':'#8b5cf6','Buba':'#f59e0b',
  'Tiny Love':'#10b981','Tutti Baby':'#f97316','Cosco Kids':'#ef4444',
  'Vittak':'#06b6d4','Pet Ninho':'#84cc16','TinyLove':'#10b981',
};

function buildBrandBar() {
  const bar = document.getElementById('brandBar');
  bar.innerHTML = '';
  const marcaMap = {};
  ALL.forEach(p => p._marcas.forEach(m => { marcaMap[m] = (marcaMap[m]||0)+1; }));
  const sorted = Object.entries(marcaMap).sort((a,b)=>b[1]-a[1]);
  if (!sorted.length) { bar.style.display='none'; return; }
  bar.style.display='';

  // "Todos" chip
  const all = document.createElement('div');
  all.className = 'brand-chip-all';
  all.id = 'brandChipAll';
  all.textContent = 'Todas';
  all.addEventListener('click', () => {
    ACTIVE.marca.clear();
    bar.querySelectorAll('.brand-chip').forEach(c => c.classList.remove('active'));
    filter();
  });
  bar.appendChild(all);

  sorted.forEach(([marca, count]) => {
    const chip = document.createElement('div');
    chip.className = 'brand-chip';
    chip.dataset.marca = marca;
    if (ACTIVE.marca.has(marca)) chip.classList.add('active');
    const color = BRAND_COLORS[marca] || 'var(--text-muted)';
    chip.innerHTML = `<div class="brand-chip-dot" style="background:${color};"></div>${esc(marca)}<span class="brand-chip-n">${count}</span>`;
    chip.addEventListener('click', () => {
      if (ACTIVE.marca.has(marca)) {
        ACTIVE.marca.delete(marca);
        chip.classList.remove('active');
      } else {
        ACTIVE.marca.add(marca);
        chip.classList.add('active');
      }
      // Sync com fp-item
      document.querySelectorAll(`.fp-item[data-filter="marca"][data-val="${CSS.escape(marca)}"]`).forEach(el => {
        el.classList.toggle('active', ACTIVE.marca.has(marca));
      });
      filter();
    });
    bar.appendChild(chip);
  });
}

/* ══ FILTROS ══ */
function buildFilterPanel() {
  const modMap = {}, grupoMap = {};
  ALL.forEach(p => {
    p._mods.forEach(m  => { modMap[m]   = (modMap[m]  ||0)+1; });
    p._grupos.forEach(g => { grupoMap[g] = (grupoMap[g]||0)+1; });
  });

  const modColors = { 'FLEX':'#f5c842','FULL':'#3b82f6','Agência':'#10b981' };
  fillFpGroup('fg-modalidade', modMap,   'modalidade', modColors);
  fillFpGroup('fg-grupo',      grupoMap, 'grupo',      {});

  // Contagens inteligência
  document.getElementById('fn-ec').textContent = ALL.filter(p=>(p.stock??0)===0).length;
  document.getElementById('fn-sp').textContent = ALL.filter(p=>!p.preco).length;
  document.getElementById('fn-sd').textContent = ALL.filter(p=>!p.width||!p.height||!p.depth).length;

  // Cadastro Redondo
  const scores = ALL.map(p=>calcScore(p));
  const avg = scores.length ? Math.round(scores.reduce((a,b)=>a+b,0)/scores.length) : 0;
  document.getElementById('redondoPct').textContent = avg+'%';
  document.getElementById('redondoBar').style.width = avg+'%';
  const sfN  = ALL.filter(p=>!hasPhoto(p)).length;
  const seN  = ALL.filter(p=>!p.ean).length;
  const sdN  = ALL.filter(p=>!p.width||!p.height||!p.depth).length;

  document.getElementById('redondoAlerts').innerHTML =
    `<div class="fp-alert t-err ${ACTIVE.alerta.has('foto')?'active':''}" data-alert="foto">
       <div class="fp-alert-dot" style="background:var(--c-err);"></div>
       Sem foto <span>${sfN}</span>
     </div>
     <div class="fp-alert t-warn ${ACTIVE.alerta.has('ean')?'active':''}" data-alert="ean">
       <div class="fp-alert-dot" style="background:var(--c-warn);"></div>
       Sem EAN <span>${seN}</span>
     </div>
     <div class="fp-alert t-warn ${ACTIVE.alerta.has('dims')?'active':''}" data-alert="dims">
       <div class="fp-alert-dot" style="background:var(--c-warn);"></div>
       Sem dimensões <span>${sdN}</span>
     </div>`;

  document.querySelectorAll('.fp-alert').forEach(el => {
    el.addEventListener('click', () => {
      const type = el.dataset.alert;
      if (ACTIVE.alerta.has(type)) ACTIVE.alerta.delete(type); else ACTIVE.alerta.add(type);
      el.classList.toggle('active', ACTIVE.alerta.has(type));
      filter();
    });
  });
}

function fillFpGroup(id, countMap, key, colors) {
  const container = document.getElementById(id);
  if (!container) return;
  const label = container.querySelector('.fp-label');
  container.innerHTML = ''; container.appendChild(label);
  const sorted = Object.entries(countMap).sort((a,b)=>b[1]-a[1]);
  if (!sorted.length) { container.style.display='none'; return; }
  container.style.display='';
  sorted.forEach(([val, count]) => {
    const div = document.createElement('div');
    div.className = 'fp-item';
    div.dataset.filter = key; div.dataset.val = val;
    if (ACTIVE[key]?.has(val)) div.classList.add('active');
    const color = colors[val]||'var(--text-muted)';
    div.innerHTML = `<div class="fp-dot" style="background:${color};"></div>${esc(val)}<span class="fp-n">${count}</span>`;
    div.addEventListener('click', () => toggleFP(div));
    container.appendChild(div);
  });
}

function toggleFP(el) {
  const key=el.dataset.filter, val=el.dataset.val, set=ACTIVE[key];
  if (set.has(val)) set.delete(val); else set.add(val);
  el.classList.toggle('active', set.has(val));
  // Sync com brand-chip se for marca
  if (key==='marca') {
    document.querySelectorAll(`.brand-chip[data-marca="${CSS.escape(val)}"]`).forEach(c=>c.classList.toggle('active',set.has(val)));
  }
  filter();
}

function updateIncompletos() {
  document.getElementById('cntSemFoto').textContent = ALL.filter(p=>!hasPhoto(p)).length;
  document.getElementById('cntSemDims').textContent = ALL.filter(p=>!p.width||!p.height||!p.depth).length;
  document.getElementById('cntSemEan').textContent  = ALL.filter(p=>!p.ean).length;
}

/* ══ FILTER ══ */
function filter() {
  const q = (document.getElementById('searchQ').value||'').toLowerCase().trim();
  FILTERED = ALL.filter(p => {
    if (EXCLUIDOS.has(p.sku)) return false;
    if (SILENCIADOS.has(p.sku) && !SHOW_SILENCIADOS) return false;
    if (q) {
      const hay = `${p.sku} ${p.name} ${p.ean||''} ${p._marcas.join(' ')}`.toLowerCase();
      if (!hay.includes(q)) return false;
    }
    if (ACTIVE.marca.size      && ![...ACTIVE.marca].some(m=>p._marcas.includes(m)))     return false;
    if (ACTIVE.modalidade.size && ![...ACTIVE.modalidade].some(m=>p._mods.includes(m)))  return false;
    if (ACTIVE.grupo.size      && ![...ACTIVE.grupo].some(g=>p._grupos.includes(g)))     return false;
    if (ACTIVE.inteligencia.has('estoque-critico') && (p.stock??0)>0) return false;
    if (ACTIVE.inteligencia.has('sem-preco')  && p.preco)             return false;
    if (ACTIVE.inteligencia.has('sem-dims')   && p.width&&p.height&&p.depth) return false;
    if (ACTIVE.alerta.has('foto')  && hasPhoto(p))                    return false;
    if (ACTIVE.alerta.has('ean')   && p.ean)                          return false;
    if (ACTIVE.alerta.has('dims')  && p.width&&p.height&&p.depth)     return false;
    return true;
  });
  PAGE = 48;
  document.getElementById('countNum').textContent = FILTERED.length;
  renderActiveChips();
  updateFilterBadge();
  render();
}

function renderActiveChips() {
  const wrap = document.getElementById('activeChips');
  wrap.innerHTML = '';
  const add = (label, cls, onRemove) => {
    const chip = document.createElement('div');
    chip.className = `active-chip${cls?' '+cls:''}`;
    chip.innerHTML = `${esc(label)}<button>✕</button>`;
    chip.querySelector('button').addEventListener('click', onRemove);
    wrap.appendChild(chip);
  };
  for (const [key, set] of Object.entries(ACTIVE)) {
    for (const val of set) {
      const cls = (key==='inteligencia'||key==='alerta') ? 't-err' : '';
      add(val, cls, () => {
        set.delete(val);
        document.querySelectorAll(`.fp-item[data-filter="${key}"][data-val="${val}"]`).forEach(el=>el.classList.remove('active'));
        if (key==='marca') document.querySelectorAll(`.brand-chip[data-marca="${CSS.escape(val)}"]`).forEach(c=>c.classList.remove('active'));
        filter();
      });
    }
  }
}

function updateFilterBadge() {
  const total = [...Object.values(ACTIVE)].reduce((s,set)=>s+set.size,0);
  const badge = document.getElementById('fltBadge');
  badge.style.display = total>0 ? '' : 'none';
  badge.textContent = total;
}

/* ══ RENDER ══ */
function render() {
  const el = document.getElementById('catalogoContent');
  el.innerHTML='';
  if (!FILTERED.length) {
    el.innerHTML=`<div class="state-msg"><div class="icon">🔍</div><p>Nenhum produto encontrado.</p></div>`;
    return;
  }
  const slice = FILTERED.slice(0, PAGE);
  const container = document.createElement('div');
  container.className = VIEW==='grid' ? 'prod-grid' : 'prod-list';
  slice.forEach(p => container.appendChild(VIEW==='grid' ? makeCard(p) : makeRow(p)));
  el.appendChild(container);
  if (FILTERED.length>PAGE) {
    const lm = document.createElement('div');
    lm.className = 'load-more';
    const btn = document.createElement('button');
    btn.className = 'lm-btn';
    btn.textContent = `Ver mais ${FILTERED.length-PAGE} produtos ↓`;
    btn.addEventListener('click', ()=>{ PAGE+=48; render(); });
    lm.appendChild(btn); el.appendChild(lm);
  }
}

function makeCard(p) {
  const foto  = bestPhoto(p);
  const score = calcScore(p);
  const sc    = scoreClass(score);
  const dims  = [p.width,p.height,p.depth].filter(Boolean).join('×');
  const div   = document.createElement('div');
  div.className='pc';
  if (SILENCIADOS.has(p.sku)) div.classList.add('pc-silenciado');
  if ((p.stock??0)===0 && !SILENCIADOS.has(p.sku)) div.classList.add('pc-zero-stock');

  const imgHtml = foto
    ? `<img class="pc-img" src="${esc(foto)}" onerror="this.style.display='none'" alt="" loading="lazy">`
    : `<div class="pc-no-foto">
        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        <div class="pc-no-foto-cta">SEM FOTO</div>
        <label class="pc-upload-overlay" title="Adicionar foto">
          <input type="file" accept="image/*" class="pc-upload-input" />
          <span>+ Adicionar foto</span>
        </label>
      </div>`;

  const zeroBadge = (p.stock??0)===0 && !SILENCIADOS.has(p.sku) ? `<span class="badge-zero">ZERO</span>` : '';

  div.innerHTML = `
    ${imgHtml}
    ${SILENCIADOS.has(p.sku) ? '<div class="badge-silenciado">🔇</div>' : ''}
    <div class="pc-badges">${zeroBadge}<span class="pc-score ${sc}">${score}%</span></div>
    <div class="pc-body">
      <div class="pc-sku">${esc(p.sku||'')}</div>
      <div class="pc-name">${esc(p.name||'')}</div>
      <div class="pc-pills">
        ${p._marcas.map(m=>`<span class="pill pill-brand">${esc(m)}</span>`).join('')}
        ${p._mods.map(m=>`<span class="pill ${m==='FLEX'?'pill-flex':m==='FULL'?'pill-full':'pill-agency'}">${esc(m)}</span>`).join('')}
      </div>
    </div>
    <div class="pc-foot">
      <span class="pc-dims">${dims?esc(dims)+'cm':''}</span>
      ${p.preco?`<span class="pc-price">R$${Number(p.preco).toFixed(2).replace('.',',')} </span>`:''}
    </div>`;

  div.addEventListener('click', e => {
    if (e.target.closest('.pc-upload-input')||e.target.closest('.pc-upload-overlay')) return;
    openModalProd(p);
  });
  const ui = div.querySelector('.pc-upload-input');
  if (ui) ui.addEventListener('change', async function(e) {
    e.stopPropagation(); if (!this.files?.length) return;
    div.style.opacity='.5'; div.style.pointerEvents='none';
    await uploadFoto(p.sku, this, 'stock');
    div.style.opacity=''; div.style.pointerEvents='';
  });
  return div;
}

function makeRow(p) {
  const foto  = bestPhoto(p);
  const score = calcScore(p);
  const sc    = scoreClass(score);
  const dims  = [p.width,p.height,p.depth].filter(Boolean).join('×');
  const div   = document.createElement('div');
  div.className='pl';
  if (SILENCIADOS.has(p.sku)) div.classList.add('pc-silenciado');
  div.innerHTML = `
    ${foto
      ?`<img class="pl-img" src="${esc(foto)}" onerror="this.style.display='none'" alt="" loading="lazy">`
      :`<div class="pl-no-foto"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>`}
    <div class="pl-info">
      <div class="pl-top">
        <span class="pl-sku">${esc(p.sku||'')}</span>
        <span class="pc-score ${sc}" style="position:static;">${score}%</span>
        ${(p.stock??0)===0?`<span class="badge-zero" style="position:static;">ZERO</span>`:''}
        ${p._mods.map(m=>`<span class="pill ${m==='FLEX'?'pill-flex':m==='FULL'?'pill-full':'pill-agency'}">${esc(m)}</span>`).join('')}
      </div>
      <div class="pl-name">${esc(p.name||'')}</div>
      <div class="pl-meta">
        ${p._marcas.map(m=>`<span class="pill pill-brand">${esc(m)}</span>`).join('')}
        ${p._grupos.map(g=>`<span class="pill pill-group">${esc(g)}</span>`).join('')}
      </div>
    </div>
    <div class="pl-right">
      <span style="font-size:9px;color:var(--text-muted);">${dims?esc(dims)+'cm':''}</span>
      ${p.weight?`<span style="font-size:9px;color:var(--text-muted);">${p.weight}kg</span>`:''}
      ${p.preco?`<span class="pc-price">R$${Number(p.preco).toFixed(2).replace('.',',')}</span>`:''}
    </div>`;
  div.addEventListener('click', ()=>openModalProd(p));
  return div;
}

function showSkeleton() {
  document.getElementById('catalogoContent').innerHTML = `<div class="prod-grid">${
    Array(16).fill(0).map(()=>`
      <div style="background:var(--depth-1);border:1px solid var(--border-subtle);border-radius:var(--r-lg);overflow:hidden;">
        <div class="skel" style="width:100%;aspect-ratio:1;"></div>
