<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>Produto Studio — Expedição Pro</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=DM+Mono:wght@400;500&family=DM+Sans:wght@400;500;700;900&family=Syne:wght@700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/erp.css" />
  <link rel="stylesheet" href="/erp-custom.css" />
  <script src="/auth-guard.js"></script>
  <style>
/* ─── TOKENS LOCAIS ─── */
:root {
  --c-ok:      var(--accent-green,  #10b981);
  --c-ok-bg:   rgba(16,185,129,.10);
  --c-ok-bd:   rgba(16,185,129,.22);
  --c-warn:    var(--accent-yellow, #f5c842);
  --c-warn-bg: rgba(245,200,66,.10);
  --c-warn-bd: rgba(245,200,66,.28);
  --c-err:     var(--accent-red,    #ef4444);
  --c-err-bg:  rgba(239,68,68,.10);
  --c-err-bd:  rgba(239,68,68,.22);
  --c-info:    var(--accent-blue,   #3b82f6);
  --c-info-bg: rgba(59,130,246,.10);
  --c-info-bd: rgba(59,130,246,.22);
}

/* Light — Material Design básico: preto/branco/cinza + semântico */
[data-theme="light"] {
  --depth-0: #f4f4f5;
  --depth-1: #ffffff;
  --depth-2: #f4f4f5;
  --depth-3: #ffffff;
  --depth-4: #f0f0f0;
  --depth-5: #e4e4e7;
  --sidebar-bg:    #ffffff;
  --main-bg:       #f4f4f5;
  --border-subtle:  rgba(0,0,0,.06);
  --border-default: rgba(0,0,0,.12);
  --border-strong:  rgba(0,0,0,.20);
  --text-primary:   #111111;
  --text-secondary: #555555;
  --text-muted:     #888888;
  --shadow-sm:  0 1px 3px rgba(0,0,0,.08);
  --shadow-md:  0 4px 12px rgba(0,0,0,.10);
  --shadow-lg:  0 8px 32px rgba(0,0,0,.12);
  --input-bg:   #ffffff;
  --input-border: rgba(0,0,0,.18);
  --accent-blue:   #1976d2;
  --accent-green:  #2e7d32;
  --accent-red:    #c62828;
  --accent-yellow: #f9a825;
  --c-ok:      #2e7d32;
  --c-ok-bg:   rgba(46,125,50,.08);
  --c-ok-bd:   rgba(46,125,50,.20);
  --c-warn:    #e65100;
  --c-warn-bg: rgba(230,81,0,.08);
  --c-warn-bd: rgba(230,81,0,.22);
  --c-err:     #c62828;
  --c-err-bg:  rgba(198,40,40,.08);
  --c-err-bd:  rgba(198,40,40,.20);
  --c-info:    #1976d2;
  --c-info-bg: rgba(25,118,210,.08);
  --c-info-bd: rgba(25,118,210,.20);
}

/* ─── LAYOUT ROOT ─── */
html, body { height:100%; }
body { overflow: hidden; }

.ps-root {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
  background: var(--main-bg, var(--depth-2));
}

/* ─── TOPBAR ─── */
.ps-topbar {
  display: flex;
  align-items: stretch;
  background: var(--sidebar-bg, var(--depth-1));
  border-bottom: 1px solid var(--border-subtle);
  height: 44px;
  flex-shrink: 0;
  z-index: 20;
}

/* Abas — estilo flat Material-like */
.ps-tabs { display:flex; align-items:stretch; flex:1; overflow-x:auto; -webkit-overflow-scrolling:touch; }
.ps-tabs::-webkit-scrollbar { display:none; }
.ps-tab {
  display: flex; align-items: center; gap: 6px;
  padding: 0 18px;
  font-family: var(--font-body);
  font-size: 13px; font-weight: 600;
  color: var(--text-muted);
  border-bottom: 3px solid transparent;
  cursor: pointer; white-space: nowrap; flex-shrink: 0;
  transition: color .15s, border-color .15s;
  background: none; border-top: none; border-left: none; border-right: none;
  letter-spacing: .01em;
}
.ps-tab svg { width:14px; height:14px; stroke:currentColor; fill:none; stroke-width:1.75; stroke-linecap:round; stroke-linejoin:round; }
.ps-tab:hover { color: var(--text-primary); }
.ps-tab.active {
  color: var(--accent-blue);
  border-bottom-color: var(--accent-blue);
  background: transparent;
}
.ps-tab-badge {
  font-size: 10px; font-weight: 700;
  padding: 1px 5px; border-radius: var(--r-full);
  background: var(--c-err-bg); color: var(--c-err);
  border: 1px solid var(--c-err-bd);
}

/* Botão Filtros */
.ps-filter-toggle {
  display: flex; align-items: center; gap: 7px;
  padding: 0 16px;
  border-left: 1px solid var(--border-subtle);
  font-family: var(--font-body); font-size: 13px; font-weight: 600;
  color: var(--text-secondary);
  cursor: pointer; white-space: nowrap; flex-shrink: 0;
  transition: background .12s, color .12s;
  background: none; border-top:none; border-right:none; border-bottom:none;
}
.ps-filter-toggle:hover { background: var(--depth-3); }
.ps-filter-toggle.open { color: var(--accent-blue); background: var(--c-info-bg); }
.ps-filter-toggle svg { width:15px; height:15px; stroke:currentColor; fill:none; stroke-width:1.75; stroke-linecap:round; stroke-linejoin:round; }
.flt-badge {
  background: var(--c-err-bg); color: var(--c-err);
  border: 1px solid var(--c-err-bd);
  font-size: 10px; font-weight: 700; padding: 1px 6px;
  border-radius: var(--r-full); line-height: 1.4;
}

/* ─── PAINEL FILTROS — drawer horizontal ─── */
.ps-filter-panel {
  background: var(--sidebar-bg, var(--depth-1));
  border-bottom: 1px solid var(--border-subtle);
  padding: 10px 16px 12px;
  display: none; gap: 20px; flex-wrap: wrap;
  flex-shrink: 0; overflow-x: auto;
}
.ps-filter-panel.open { display: flex; }
.fp-group { display:flex; flex-direction:column; gap:2px; min-width:130px; }
.fp-label { font-size:9px; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:.7px; padding:0 6px 4px; }
.fp-item {
  display:flex; align-items:center; gap:7px; padding:4px 8px;
  border-radius: var(--r-sm); cursor:pointer; font-size:12px; font-weight:500;
  color: var(--text-secondary); transition: background .12s, color .12s;
  border: 1px solid transparent;
}
.fp-item:hover { background: var(--depth-3); color: var(--text-primary); }
.fp-item.active { background: var(--c-info-bg); border-color: var(--c-info-bd); color: var(--accent-blue); }
.fp-dot { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
.fp-n { font-size:10px; color:var(--text-muted); margin-left:auto; font-family:var(--font-numeric,'DM Mono',monospace); }
.fp-item.active .fp-n { color: var(--accent-blue); }

/* Cadastro Redondo no painel */
.fp-redondo {
  background: var(--depth-3); border: 1px solid var(--border-default);
  border-radius: var(--r-md); padding: 9px 11px; margin-bottom: 4px;
}
.fp-redondo-hdr { display:flex; align-items:center; justify-content:space-between; margin-bottom:5px; }
.fp-redondo-pct { font-size:12px; font-weight:700; color: var(--c-warn); font-family: var(--font-numeric,'DM Mono',monospace); }
.fp-prog { height:4px; border-radius:2px; background:var(--depth-5); overflow:hidden; margin-bottom:7px; }
.fp-prog-fill { height:100%; border-radius:2px; background: var(--c-warn); transition: width .3s ease; }
.fp-alert { display:flex; align-items:center; gap:6px; padding:3px 0; font-size:11px; cursor:pointer; }
.fp-alert:hover { opacity:.75; }
.fp-alert.active { font-weight:700; }
.fp-alert.t-err  { color: var(--c-err); }
.fp-alert.t-warn { color: var(--c-warn); }
.fp-alert-dot { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
.fp-alert span:last-child { margin-left:auto; font-family:var(--font-numeric,'DM Mono',monospace); font-size:10px; }

/* ─── TOOLBAR — linha com busca + chips ativos ─── */
.ps-toolbar {
  display: flex; align-items: center; gap: 8px;
  padding: 7px 14px;
  border-bottom: 1px solid var(--border-subtle);
  background: var(--sidebar-bg, var(--depth-1));
  flex-shrink: 0; flex-wrap: wrap;
}
.ps-search-wrap {
  display: flex; align-items: center; gap: 7px;
  height: 32px; padding: 0 10px;
  background: var(--input-bg, var(--depth-3));
  border: 1px solid var(--input-border, var(--border-default));
  border-radius: var(--r-md);
  min-width: 180px; flex: 0 0 auto;
  transition: border-color .15s, box-shadow .15s;
}
.ps-search-wrap:focus-within {
  border-color: var(--accent-blue);
  box-shadow: 0 0 0 3px var(--c-info-bg);
}
.ps-search-wrap svg { width:13px; height:13px; stroke:var(--text-muted); fill:none; stroke-width:1.75; flex-shrink:0; }
.ps-search-wrap input { background:none; border:none; outline:none; font-family:var(--font-body); font-size:13px; color:var(--text-primary); width:100%; }
.ps-search-wrap input::placeholder { color:var(--text-muted); }
.ps-search-clear { background:none; border:none; color:var(--text-muted); cursor:pointer; font-size:17px; line-height:1; padding:0; display:none; }
.ps-search-clear:hover { color:var(--text-primary); }

/* ─── CHIPS DE MARCA — segunda linha ─── */
.ps-brand-bar {
  display: flex; align-items: center; gap: 6px;
  padding: 6px 14px;
  border-bottom: 1px solid var(--border-subtle);
  background: var(--sidebar-bg, var(--depth-1));
  overflow-x: auto; -webkit-overflow-scrolling: touch;
  flex-shrink: 0;
}
.ps-brand-bar::-webkit-scrollbar { height: 0; }
.brand-chip {
  display: flex; align-items: center; gap: 5px;
  padding: 4px 10px; border-radius: var(--r-full);
  border: 1px solid var(--border-default);
  background: var(--depth-3);
  font-family: var(--font-body); font-size: 11px; font-weight: 600;
  color: var(--text-secondary);
  cursor: pointer; white-space: nowrap; flex-shrink: 0;
  transition: all .12s ease;
}
.brand-chip:hover { border-color: var(--accent-blue); color: var(--accent-blue); }
.brand-chip.active {
  background: var(--accent-blue); border-color: var(--accent-blue);
  color: #fff;
}
.brand-chip.active .brand-chip-dot { opacity: .7; }
.brand-chip-dot { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
.brand-chip-n { font-size:10px; opacity:.7; font-family:var(--font-numeric,'DM Mono',monospace); }
.brand-chip-all {
  display:flex; align-items:center; padding:4px 10px;
  border-radius:var(--r-full); border:1px solid var(--border-default);
  background:var(--depth-3); font-size:11px; font-weight:600;
  color:var(--text-muted); cursor:pointer; white-space:nowrap; flex-shrink:0;
  transition:all .12s;
}
.brand-chip-all:hover { border-color:var(--border-strong); color:var(--text-primary); }

/* Chips ativos na toolbar */
.active-chips { display:flex; gap:5px; flex-wrap:wrap; }
.active-chip {
  display:flex; align-items:center; gap:4px; font-size:11px; font-weight:600;
  padding:2px 8px 2px 10px; border-radius:var(--r-full);
  border:1px solid var(--c-info-bd); background:var(--c-info-bg); color:var(--accent-blue);
}
.active-chip.t-err  { border-color:var(--c-err-bd);  background:var(--c-err-bg);  color:var(--c-err);  }
.active-chip.t-warn { border-color:var(--c-warn-bd); background:var(--c-warn-bg); color:var(--c-warn); }
.active-chip button { background:none; border:none; color:inherit; cursor:pointer; font-size:14px; line-height:1; padding:0; margin-left:2px; }

.ps-count { font-size:12px; color:var(--text-muted); white-space:nowrap; margin-left:auto; }
.ps-count strong { font-family:var(--font-numeric,'DM Mono',monospace); color:var(--text-primary); }
.view-btns { display:flex; gap:3px; flex-shrink:0; }
.vb {
  background:var(--depth-3); border:1px solid var(--border-default);
  border-radius:var(--r-sm); padding:5px 9px; cursor:pointer; font-size:14px;
  color:var(--text-muted); transition:all .12s; line-height:1;
}
.vb.on { background:var(--accent-blue); color:#fff; border-color:var(--accent-blue); }

/* ─── BODY / PANES ─── */
.ps-body { flex:1; min-height:0; overflow:hidden; display:flex; flex-direction:column; }

/* ─── PANE CATÁLOGO ─── */
#pane-catalogo {
  flex:1; min-height:0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 14px;
}
#pane-catalogo::-webkit-scrollbar { width:5px; }
#pane-catalogo::-webkit-scrollbar-thumb { background:var(--depth-4); border-radius:3px; }

.prod-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(170px,1fr));
  gap: 10px;
}
.prod-list { display:flex; flex-direction:column; gap:6px; }

/* Card */
.pc {
  background: var(--depth-1); border:1px solid var(--border-subtle);
  border-radius: var(--r-lg); overflow:hidden; cursor:pointer; position:relative;
  transition: transform .15s, box-shadow .15s, border-color .15s;
}
.pc:hover { transform:translateY(-2px); box-shadow:var(--shadow-md); border-color:var(--border-default); }
.pc-img { width:100%; aspect-ratio:1; object-fit:cover; background:var(--depth-3); display:block; }
.pc-no-foto {
  width:100%; aspect-ratio:1; background:var(--depth-3);
  display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; position:relative;
}
.pc-no-foto svg { width:28px; height:28px; stroke:var(--text-muted); fill:none; stroke-width:1.4; opacity:.25; }
.pc-no-foto-cta { font-size:9px; font-weight:700; color:var(--accent-blue); letter-spacing:.3px; }
.pc-upload-overlay {
  position:absolute; inset:0;
  background:var(--c-info-bg); border:2px dashed var(--accent-blue);
  display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px;
  opacity:0; transition:opacity .15s; cursor:pointer;
}
.pc-upload-overlay:hover, .pc-no-foto:hover .pc-upload-overlay { opacity:1; }
.pc-upload-overlay span { font-size:11px; font-weight:700; color:var(--accent-blue); }
.pc-upload-input { display:none; }

/* Badges — agrupados no canto, nunca sobrepostos */
.pc-badges {
  position:absolute; top:6px; right:6px;
  display:flex; gap:3px; align-items:center; flex-wrap:nowrap;
}
.pc-score {
  font-size:9px; font-weight:700; padding:2px 6px;
  border-radius:var(--r-full); line-height:1.4; white-space:nowrap;
}
.pc-score.full { background:var(--c-ok-bg);   color:var(--c-ok);   border:1px solid var(--c-ok-bd); }
.pc-score.mid  { background:var(--c-warn-bg);  color:var(--c-warn); border:1px solid var(--c-warn-bd); }
.pc-score.low  { background:var(--c-err-bg);   color:var(--c-err);  border:1px solid var(--c-err-bd); }
.badge-zero {
  font-size:9px; font-weight:700; padding:2px 6px;
  border-radius:var(--r-full); line-height:1.4; white-space:nowrap;
  background:var(--c-err-bg); color:var(--c-err); border:1px solid var(--c-err-bd);
}
.badge-silenciado {
  position:absolute; top:6px; left:6px;
  background:var(--c-warn-bg); border:1px solid var(--c-warn-bd);
  border-radius:var(--r-full); padding:2px 7px; font-size:9px; font-weight:700; color:var(--c-warn); z-index:2;
}
.pc-silenciado { opacity:.3; filter:grayscale(.4); }
.pc-silenciado:hover { opacity:.55; }
.pc-zero-stock { opacity:.45; }
.pc-zero-stock:hover { opacity:.7; }

.pc-body { padding:8px 10px; }
.pc-sku { font-family:var(--font-numeric,'DM Mono',monospace); font-size:9px; color:var(--accent-blue); font-weight:700; margin-bottom:3px; }
.pc-name { font-size:12px; font-weight:600; line-height:1.3; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; color:var(--text-primary); }
.pc-pills { display:flex; gap:3px; flex-wrap:wrap; margin-top:5px; }
.pc-foot { padding:5px 10px; border-top:1px solid var(--border-subtle); background:var(--depth-2); display:flex; justify-content:space-between; align-items:center; }
.pc-dims { font-size:9px; color:var(--text-muted); }
.pc-price { font-size:10px; color:var(--c-ok); font-weight:700; font-family:var(--font-numeric,'DM Mono',monospace); }

/* Row lista */
.pl {
  background:var(--depth-1); border:1px solid var(--border-subtle);
  border-radius:var(--r-md); display:grid;
  grid-template-columns:56px 1fr auto;
  overflow:hidden; cursor:pointer; transition:background .12s, border-color .12s;
}
.pl:hover { background:var(--depth-3); border-color:var(--border-default); }
.pl-img { width:56px; height:56px; object-fit:cover; background:var(--depth-3); display:block; }
.pl-no-foto { width:56px; height:56px; display:flex; align-items:center; justify-content:center; background:var(--depth-3); }
.pl-no-foto svg { width:18px; height:18px; stroke:var(--text-muted); fill:none; stroke-width:1.4; opacity:.25; }
.pl-info { padding:8px 12px; display:flex; flex-direction:column; justify-content:center; gap:3px; min-width:0; }
.pl-top { display:flex; align-items:center; gap:6px; flex-wrap:wrap; }
.pl-sku { font-family:var(--font-numeric,'DM Mono',monospace); font-size:10px; color:var(--accent-blue); font-weight:700; }
.pl-name { font-size:13px; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; color:var(--text-primary); }
.pl-meta { display:flex; gap:5px; flex-wrap:wrap; align-items:center; }
.pl-right { padding:8px 11px; display:flex; flex-direction:column; align-items:flex-end; justify-content:center; gap:3px; border-left:1px solid var(--border-subtle); background:var(--depth-2); min-width:75px; }

/* Pills */
.pill { font-size:9px; font-weight:700; padding:2px 6px; border-radius:var(--r-full); }
.pill-brand  { background:rgba(139,92,246,.12); color:#7c3aed; border:1px solid rgba(139,92,246,.2); }
.pill-full   { background:var(--c-info-bg); color:var(--accent-blue); border:1px solid var(--c-info-bd); }
.pill-flex   { background:rgba(245,200,66,.85); color:#555; }
.pill-agency { background:var(--c-ok-bg); color:var(--c-ok); border:1px solid var(--c-ok-bd); }
.pill-group  { background:var(--depth-4); color:var(--text-muted); border:1px solid var(--border-default); }

/* Load more */
.load-more { display:flex; justify-content:center; padding:20px 0; }
.lm-btn {
  background:var(--depth-3); border:1px solid var(--border-default);
  border-radius:var(--r-md); padding:10px 28px; cursor:pointer;
  font-family:var(--font-body); font-weight:600; font-size:13px; color:var(--text-muted);
  transition:all .12s;
}
.lm-btn:hover { background:var(--depth-4); color:var(--text-primary); }

/* Skeleton */
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
.skel {
  background:linear-gradient(90deg,var(--depth-3) 25%,var(--depth-4) 50%,var(--depth-3) 75%);
  background-size:200% 100%; animation:shimmer 1.4s infinite;
}
.state-msg { display:flex; flex-direction:column; align-items:center; justify-content:center; height:300px; gap:10px; color:var(--text-muted); }
.state-msg .icon { font-size:44px; opacity:.2; }
.state-msg p { font-size:14px; }

/* ─── PANE STUDIO ─── */
#pane-studio {
  flex:1; min-height:0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
#pane-studio::-webkit-scrollbar { width:5px; }
#pane-studio::-webkit-scrollbar-thumb { background:var(--depth-4); border-radius:3px; }

.studio-empty {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:12px; color:var(--text-muted); padding:60px 40px; text-align:center;
}
.studio-empty svg { width:48px; height:48px; stroke:currentColor; fill:none; stroke-width:1.2; opacity:.2; }
.studio-empty p { font-size:14px; }

/* Studio header */
.st-header { display:flex; align-items:flex-start; gap:14px; flex-wrap:wrap; }
.st-title-block { flex:1; min-width:200px; }
.st-sku { font-family:var(--font-numeric,'DM Mono',monospace); font-size:10px; color:var(--accent-blue); font-weight:700; margin-bottom:4px; }
.st-name { font-size:18px; font-weight:800; font-family:var(--font-display,'Syne',sans-serif); color:var(--text-primary); line-height:1.25; }
.st-pills { display:flex; gap:5px; flex-wrap:wrap; margin-top:6px; }

/* Score inline */
.score-inline {
  display:flex; align-items:center; gap:10px; padding:8px 12px;
  background:var(--depth-3); border:1px solid var(--border-default);
  border-radius:var(--r-md); flex-shrink:0;
}
.score-label { font-size:11px; color:var(--text-secondary); font-weight:600; }
.score-bar { width:90px; height:5px; border-radius:3px; background:var(--depth-5); overflow:hidden; }
.score-fill { height:100%; border-radius:3px; transition:width .4s ease; }
.score-fill.full { background:var(--c-ok); }
.score-fill.mid  { background:var(--c-warn); }
.score-fill.low  { background:var(--c-err); }
.score-pct { font-size:13px; font-weight:700; font-family:var(--font-numeric,'DM Mono',monospace); }
.score-pct.full { color:var(--c-ok); }
.score-pct.mid  { color:var(--c-warn); }
.score-pct.low  { color:var(--c-err); }
.score-checks { display:flex; gap:5px; }
.sc-dot { width:8px; height:8px; border-radius:50%; }

/* Galeria */
.st-gallery { display:flex; gap:8px; align-items:flex-start; flex-wrap:wrap; }
.st-photo-main { width:130px; height:130px; flex-shrink:0; border-radius:var(--r-md); object-fit:cover; background:var(--depth-3); border:1px solid var(--border-subtle); display:block; }
.st-thumbs { display:flex; gap:6px; flex-wrap:wrap; align-items:flex-start; }
.st-thumb { width:60px; height:60px; border-radius:var(--r-sm); object-fit:cover; background:var(--depth-3); border:1px solid var(--border-subtle); display:block; cursor:pointer; transition:border-color .12s; }
.st-thumb:hover { border-color:var(--accent-blue); }
.st-thumb-add { width:60px; height:60px; border-radius:var(--r-sm); border:1px dashed var(--border-default); display:flex; align-items:center; justify-content:center; cursor:pointer; background:var(--depth-3); transition:all .12s; }
.st-thumb-add:hover { border-color:var(--accent-blue); background:var(--c-info-bg); }
.st-thumb-add svg { width:18px; height:18px; stroke:var(--text-muted); fill:none; stroke-width:1.75; }
.st-thumb-add input { display:none; }

/* Sub-abas Studio */
.st-subtabs { display:flex; border-bottom:1px solid var(--border-subtle); overflow-x:auto; flex-shrink:0; }
.st-subtabs::-webkit-scrollbar { display:none; }
.st-stab {
  padding:7px 13px; font-family:var(--font-body); font-size:12px; font-weight:600;
  color:var(--text-muted); border-bottom:2px solid transparent; cursor:pointer; white-space:nowrap;
  transition:color .12s, border-color .12s; background:none; border-top:none; border-left:none; border-right:none;
}
.st-stab:hover { color:var(--text-primary); }
.st-stab.active { color:var(--accent-blue); border-bottom-color:var(--accent-blue); }
.st-tab-content { display:none; }
.st-tab-content.active { display:block; }

/* Info grid */
.info-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(108px,1fr)); gap:7px; }
.ig-box { background:var(--depth-3); border:1px solid var(--border-subtle); border-radius:var(--r-md); padding:9px 11px; }
.ig-lbl { font-size:9px; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:.5px; margin-bottom:4px; }
.ig-val { font-family:var(--font-numeric,'DM Mono',monospace); font-size:13px; font-weight:700; color:var(--text-primary); }
.ig-val.blue  { color:var(--accent-blue); }
.ig-val.green { color:var(--c-ok); }
.ig-val.warn  { color:var(--c-warn); }
.ig-val.red   { color:var(--c-err); }

/* Checklist */
.st-checklist { display:flex; flex-direction:column; gap:5px; }
.sc-row { display:flex; align-items:center; gap:8px; padding:7px 10px; background:var(--depth-3); border:1px solid var(--border-subtle); border-radius:var(--r-sm); font-size:12px; }
.sc-row.ok { border-color:var(--c-ok-bd); }
.sc-row.no { border-color:var(--c-err-bd); }
.sc-row-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
.sc-row-label { flex:1; color:var(--text-secondary); font-weight:500; }
.sc-row.ok .sc-row-label { color:var(--text-primary); }
.sc-row-action { font-size:11px; color:var(--accent-blue); cursor:pointer; font-weight:700; }
.sc-row-action:hover { text-decoration:underline; }

/* BI mini */
.bi-panel { background:var(--depth-3); border:1px solid var(--border-subtle); border-radius:var(--r-md); padding:12px 14px; }
.bi-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
.bi-title { font-size:12px; font-weight:700; color:var(--text-secondary); }
.bi-empty { font-size:11px; color:var(--text-muted); text-align:center; padding:16px; line-height:1.6; }
.bi-bars { display:flex; align-items:flex-end; gap:4px; height:48px; }
.bi-bar { flex:1; border-radius:2px 2px 0 0; background:var(--c-info-bg); border:1px solid var(--c-info-bd); border-bottom:none; }
.bi-bar.hi { background:var(--accent-blue); border-color:var(--accent-blue); }

/* Ações Studio */
.st-actions { display:flex; gap:7px; flex-wrap:wrap; }

/* ─── PANE CADASTRO ─── */
#pane-cadastro { flex:1; min-height:0; display:flex; overflow:hidden; }

.cad-methods {
  width:200px; flex-shrink:0; border-right:1px solid var(--border-subtle);
  padding:12px 8px; display:flex; flex-direction:column; gap:3px; overflow-y:auto;
}
.cad-methods-label { font-size:9px; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:.7px; padding:2px 8px 8px; }
.cad-m {
  display:flex; align-items:center; gap:8px; padding:8px 10px;
  border-radius:var(--r-md); cursor:pointer; border:1px solid transparent;
  transition:all .12s;
}
.cad-m:hover { border-color:var(--border-default); background:var(--depth-3); }
.cad-m.active { border-color:var(--c-info-bd); background:var(--c-info-bg); }
.cad-m-icon { width:26px; height:26px; border-radius:var(--r-sm); background:var(--depth-4); display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:background .12s; }
.cad-m-icon svg { width:13px; height:13px; stroke:var(--text-muted); fill:none; stroke-width:1.75; stroke-linecap:round; stroke-linejoin:round; }
.cad-m.active .cad-m-icon { background:var(--c-info-bg); }
.cad-m.active .cad-m-icon svg { stroke:var(--accent-blue); }
.cad-m-info { flex:1; min-width:0; }
.cad-m-label { font-size:12px; font-weight:600; color:var(--text-primary); }
.cad-m.active .cad-m-label { color:var(--accent-blue); }
.cad-m-sub { font-size:10px; color:var(--text-muted); margin-top:1px; }
.cad-badge { font-size:9px; padding:2px 6px; border-radius:var(--r-full); background:var(--c-ok-bg); color:var(--c-ok); border:1px solid var(--c-ok-bd); font-weight:700; white-space:nowrap; }
.cad-divider { height:1px; background:var(--border-subtle); margin:7px 0; }

/* Incompletos */
.cad-incomplete { padding:2px 8px 4px; }
.cad-incomplete-label { font-size:9px; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:.7px; margin-bottom:4px; }
.cad-inc-row { display:flex; align-items:center; gap:7px; padding:5px 8px; border-radius:var(--r-sm); cursor:pointer; font-size:11px; transition:background .12s; }
.cad-inc-row:hover { background:var(--depth-3); }
.cad-inc-dot { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
.cad-inc-label { flex:1; }
.cad-inc-row.t-err  .cad-inc-label, .cad-inc-row.t-err  .cad-inc-count { color:var(--c-err); }
.cad-inc-row.t-warn .cad-inc-label, .cad-inc-row.t-warn .cad-inc-count { color:var(--c-warn); }
.cad-inc-count { font-family:var(--font-numeric,'DM Mono',monospace); font-size:10px; font-weight:700; }

/* Área principal */
.cad-main { flex:1; padding:14px; display:flex; flex-direction:column; gap:10px; overflow-y:auto; -webkit-overflow-scrolling:touch; }
.cad-main::-webkit-scrollbar { width:5px; }
.cad-main::-webkit-scrollbar-thumb { background:var(--depth-4); border-radius:3px; }

.cad-drop-zone {
  border:2px dashed var(--border-default); border-radius:var(--r-lg); padding:30px 24px;
  text-align:center; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:9px;
  cursor:pointer; transition:border-color .15s, background .15s; background:var(--depth-3); min-height:160px;
}
.cad-drop-zone:hover,.cad-drop-zone.drag-over { border-color:var(--accent-blue); background:var(--c-info-bg); }
.cad-drop-zone svg { width:34px; height:34px; stroke:var(--text-muted); fill:none; stroke-width:1.4; opacity:.4; }
.cad-drop-title { font-size:14px; font-weight:700; color:var(--text-secondary); }
.cad-drop-sub { font-size:11px; color:var(--text-muted); }
.cad-drop-input { display:none; }

.cad-result { background:var(--depth-1); border:1px solid var(--border-default); border-radius:var(--r-lg); padding:14px 16px; display:flex; flex-direction:column; gap:11px; }
.cad-result-header { display:flex; align-items:center; justify-content:space-between; gap:12px; }
.cad-result-title { font-size:13px; font-weight:700; color:var(--text-primary); }
.cad-result-sub { font-size:11px; color:var(--c-ok); font-weight:600; }
.cad-form { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
.cad-form .wide { grid-column:span 2; }
.cad-field-wrap { display:flex; flex-direction:column; gap:4px; }
.cad-field-label { font-size:10px; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:.4px; }
.cad-field-input {
  height:32px; background:var(--input-bg,var(--depth-3)); border:1px solid var(--input-border,var(--border-default));
  border-radius:var(--r-sm); padding:0 10px; font-family:var(--font-body); font-size:13px; color:var(--text-primary);
  outline:none; transition:border-color .15s, box-shadow .15s;
}
.cad-field-input:focus { border-color:var(--accent-blue); box-shadow:0 0 0 3px var(--c-info-bg); }
.cad-field-input.filled { border-color:var(--c-ok-bd); background:var(--c-ok-bg); }
.cad-field-input::placeholder { color:var(--text-muted); }

.cad-save {
  display:flex; align-items:center; justify-content:center; gap:8px;
  height:40px; border-radius:var(--r-md); background:var(--accent-green,#10b981);
  border:none; color:#fff; font-family:var(--font-body); font-size:13px; font-weight:700;
  cursor:pointer; transition:filter .15s, transform .15s; width:100%;
}
.cad-save:hover { filter:brightness(1.08); transform:translateY(-1px); }
.cad-save:disabled { opacity:.5; cursor:not-allowed; transform:none; }
.cad-save svg { width:14px; height:14px; stroke:currentColor; fill:none; stroke-width:1.75; stroke-linecap:round; stroke-linejoin:round; }

/* ─── MODAIS ─── */
.modal { position:fixed; inset:0; z-index:200; display:flex; align-items:center; justify-content:center; padding:16px; }
.modal.hidden { display:none; }
.modal-bd { position:absolute; inset:0; background:rgba(0,0,0,.65); backdrop-filter:blur(4px); }
.modal-panel {
  position:relative; width:min(640px,100%); max-height:90vh;
  background:var(--sidebar-bg,var(--depth-1)); border-radius:var(--r-xl);
  box-shadow:var(--shadow-lg); overflow:hidden; display:flex; flex-direction:column;
  border:1px solid var(--border-subtle);
}
.modal-sm { width:min(400px,100%); }
.modal-hdr { padding:14px 18px; border-bottom:1px solid var(--border-subtle); display:flex; align-items:flex-start; justify-content:space-between; gap:10px; }
.modal-x { background:none; border:none; color:var(--text-muted); font-size:20px; cursor:pointer; padding:4px 8px; border-radius:var(--r-sm); flex-shrink:0; transition:background .12s; }
.modal-x:hover { background:var(--depth-3); color:var(--text-primary); }
.modal-body { overflow-y:auto; padding:16px; display:flex; flex-direction:column; gap:12px; }
.modal-footer { padding:12px 16px; border-top:1px solid var(--border-subtle); background:var(--depth-2); display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
.form-field { display:flex; flex-direction:column; gap:5px; }
.form-field label { font-size:10px; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:.4px; }
.form-field input,.form-field textarea,.form-field select {
  background:var(--input-bg,var(--depth-3)); border:1px solid var(--input-border,var(--border-default));
  border-radius:var(--r-md); padding:8px 11px; color:var(--text-primary);
  font-family:var(--font-body); font-size:13px; outline:none; width:100%;
  transition:border-color .15s;
}
.form-field input:focus,.form-field textarea:focus { border-color:var(--accent-blue); box-shadow:0 0 0 3px var(--c-info-bg); }

/* ─── MOBILE TAB-BAR ─── */
.ps-mobile-tabbar {
  display:none; border-top:1px solid var(--border-subtle);
  background:var(--sidebar-bg,var(--depth-1)); flex-shrink:0; z-index:20;
}
.ps-mob-tab {
  flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;
  padding:6px 2px; gap:3px; cursor:pointer; border:none; background:none; font-family:var(--font-body);
}
.ps-mob-tab svg { width:18px; height:18px; stroke:var(--text-muted); fill:none; stroke-width:1.75; stroke-linecap:round; stroke-linejoin:round; }
.ps-mob-tab.active svg { stroke:var(--accent-blue); }
.ps-mob-tab-lbl { font-size:9px; color:var(--text-muted); font-weight:600; }
.ps-mob-tab.active .ps-mob-tab-lbl { color:var(--accent-blue); }

/* ─── RESPONSIVO ─── */
@media (max-width:768px) {
  .ps-filter-toggle { display:none; }
  .ps-filter-panel  { display:none !important; }
  .ps-tabs { display:none; }
  .ps-mobile-tabbar { display:flex; }
  .ps-toolbar { padding:6px 10px; }
  .ps-search-wrap { min-width:0; flex:1; }
  .view-btns { display:none; }
  .ps-count { display:none; }
  .cad-methods { display:none; }
  #pane-cadastro { flex-direction:column; }
  .prod-grid { grid-template-columns:repeat(auto-fill,minmax(145px,1fr)); gap:8px; }
  .st-photo-main { width:100px; height:100px; }
  .score-bar { width:60px; }
  .st-name { font-size:15px; }
  #pane-catalogo { padding:10px; }
  #pane-studio { padding:10px; }
}
@media (max-width:480px) {
  .prod-grid { grid-template-columns:repeat(2,1fr); }
  .info-grid { grid-template-columns:repeat(2,1fr); }
  .cad-form { grid-template-columns:1fr; }
  .cad-form .wide { grid-column:span 1; }
}
  </style>
</head>
<body>
<div class="erp-layout">
  <div id="sidebar-placeholder"></div>
  <main class="erp-main" style="overflow:hidden;min-height:0;">

    <div class="ps-root">

      <!-- TOPBAR -->
      <div class="ps-topbar">
        <div class="ps-tabs" role="tablist">
          <button class="ps-tab active" data-tab="catalogo">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Catálogo
          </button>
          <button class="ps-tab" data-tab="studio">
            <svg viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            Studio
          </button>
          <button class="ps-tab" data-tab="cadastro">
            <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
            Cadastrar
          </button>
        </div>
        <button class="ps-filter-toggle" id="filterToggle">
          <svg viewBox="0 0 24 24"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="12" y1="18" x2="12" y2="18" stroke-linecap="round" stroke-width="2.5"/></svg>
          Filtros
          <span class="flt-badge" id="fltBadge" style="display:none;">0</span>
        </button>
      </div>

      <!-- PAINEL FILTROS -->
      <div class="ps-filter-panel" id="filterPanel">
        <div class="fp-group" style="min-width:190px;">
          <div class="fp-label">Cadastro Redondo</div>
          <div class="fp-redondo">
            <div class="fp-redondo-hdr">
              <span style="font-size:11px;font-weight:600;color:var(--text-secondary);">Catálogo geral</span>
              <span class="fp-redondo-pct" id="redondoPct">–</span>
            </div>
            <div class="fp-prog"><div class="fp-prog-fill" id="redondoBar" style="width:0%"></div></div>
            <div id="redondoAlerts"></div>
          </div>
        </div>
        <div class="fp-group">
          <div class="fp-label">Inteligência</div>
          <div class="fp-item" data-filter="inteligencia" data-val="estoque-critico" id="fi-ec">
            <div class="fp-dot" style="background:var(--c-warn);"></div>
            Estoque crítico
            <span class="fp-n" id="fn-ec">–</span>
          </div>
          <div class="fp-item" data-filter="inteligencia" data-val="sem-preco" id="fi-sp">
            <div class="fp-dot" style="background:var(--c-err);"></div>
            Sem preço
            <span class="fp-n" id="fn-sp">–</span>
          </div>
          <div class="fp-item" data-filter="inteligencia" data-val="sem-dims" id="fi-sd">
            <div class="fp-dot" style="background:var(--c-info);"></div>
            Sem dimensões
            <span class="fp-n" id="fn-sd">–</span>
          </div>
        </div>
        <div class="fp-group" id="fg-modalidade">
          <div class="fp-label">Modalidade</div>
        </div>
        <div class="fp-group" id="fg-grupo">
          <div class="fp-label">Grupo</div>
        </div>
      </div>

      <!-- TOOLBAR: busca + chips ativos + grade/lista -->
      <div class="ps-toolbar">
        <div class="ps-search-wrap">
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" id="searchQ" placeholder="Buscar produto…" autocomplete="off" />
          <button class="ps-search-clear" id="searchClear">×</button>
        </div>
        <div class="active-chips" id="activeChips"></div>
        <span class="ps-count"><strong id="countNum">–</strong> produtos</span>
        <div class="view-btns">
          <button class="vb on" id="vbGrid" title="Grade">⊞</button>
          <button class="vb" id="vbList" title="Lista">☰</button>
        </div>
      </div>

      <!-- SEGUNDA LINHA: chips de marca -->
      <div class="ps-brand-bar" id="brandBar"></div>

      <!-- BODY -->
      <div class="ps-body">

        <!-- PANE CATÁLOGO -->
        <div id="pane-catalogo" role="tabpanel">
          <div id="catalogoContent"></div>
        </div>

        <!-- PANE STUDIO -->
        <div id="pane-studio" role="tabpanel" style="display:none;">
          <div class="studio-empty" id="studioEmpty">
            <svg viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            <p>Selecione um produto no Catálogo para abrir o Studio</p>
          </div>
          <div id="studioContent" style="display:none;"></div>
        </div>

        <!-- PANE CADASTRO -->
        <div id="pane-cadastro" role="tabpanel" style="display:none;">
          <div class="cad-methods">
            <div class="cad-methods-label">Origem</div>
            <div class="cad-m active" data-method="pdf">
              <div class="cad-m-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
              <div class="cad-m-info"><div class="cad-m-label">PDF fornecedor</div><div class="cad-m-sub">IA extrai campos</div></div>
              <span class="cad-badge">Principal</span>
            </div>
            <div class="cad-m" data-method="xml">
              <div class="cad-m-icon"><svg viewBox="0 0 24 24"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg></div>
              <div class="cad-m-info"><div class="cad-m-label">XML / Bling</div><div class="cad-m-sub">dados técnicos</div></div>
            </div>
            <div class="cad-m" data-method="pesquisa">
              <div class="cad-m-icon"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></div>
              <div class="cad-m-info"><div class="cad-m-label">Pesquisa</div><div class="cad-m-sub">EAN, nome ou URL</div></div>
            </div>
            <div class="cad-m" data-method="manual">
              <div class="cad-m-icon"><svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></div>
              <div class="cad-m-info"><div class="cad-m-label">Manual</div><div class="cad-m-sub">último recurso</div></div>
            </div>
            <div class="cad-divider"></div>
            <div class="cad-incomplete">
              <div class="cad-incomplete-label">Incompletos</div>
              <div class="cad-inc-row t-err" id="incSemFoto">
                <div class="cad-inc-dot" style="background:var(--c-err);"></div>
                <span class="cad-inc-label">Sem foto</span>
                <span class="cad-inc-count" id="cntSemFoto">–</span>
              </div>
              <div class="cad-inc-row t-warn" id="incSemDims">
                <div class="cad-inc-dot" style="background:var(--c-warn);"></div>
                <span class="cad-inc-label">Sem dimensões</span>
                <span class="cad-inc-count" id="cntSemDims">–</span>
              </div>
              <div class="cad-inc-row t-warn" id="incSemEan">
                <div class="cad-inc-dot" style="background:var(--c-warn);"></div>
                <span class="cad-inc-label">Sem EAN</span>
                <span class="cad-inc-count" id="cntSemEan">–</span>
              </div>
            </div>
          </div>
          <div class="cad-main" id="cadMain"></div>
        </div>

      </div><!-- /ps-body -->

      <!-- MOBILE TAB-BAR -->
      <div class="ps-mobile-tabbar">
