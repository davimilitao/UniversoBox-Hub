/* ══ UPLOAD ══ */
async function uploadFoto(sku, input, kind='stock') {
  if (!input.files?.length) return;
  const formData = new FormData();
  formData.append('file', input.files[0]);
  formData.append('kind', kind);
  try {
    const res = await fetch(`/admin/save-photo-cloudinary/${encodeURIComponent(sku)}`, {
      method:'POST',
      headers:{'authorization':`Bearer ${localStorage.getItem('expedicao_token')||''}`},
      body:formData
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();
    if (data.ok) {
      const idx = ALL.findIndex(p=>p.sku===sku);
      if (idx>=0) {
        if (!ALL[idx].override) ALL[idx].override={};
        if (!Array.isArray(ALL[idx].override.stockPhotos)) ALL[idx].override.stockPhotos=[];
        ALL[idx].override.stockPhotos.unshift(data.url||'');
        ALL[idx].displayImage = data.url||ALL[idx].displayImage;
      }
      buildFilterPanel(); buildBrandBar(); updateIncompletos(); filter();
    }
  } catch(e) { alert('Erro no upload: '+e.message); }
  input.value='';
}

