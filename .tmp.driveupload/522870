<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"/>
  <title>Cadastrar Produto — Expedição Pro</title>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/erp.css"/>
  <link rel="stylesheet" href="/erp-custom.css">
  <style>
    .cad-layout {
      display: grid;
      grid-template-columns: 1fr 380px;
      gap: 20px;
      padding: 20px;
      max-width: 1300px;
      margin: 0 auto;
    }
    @media(max-width:900px){ .cad-layout{grid-template-columns:1fr;} }

    /* Drop zone */
    .drop-zone {
      border: 2px dashed var(--border-default);
      border-radius: var(--r-lg);
      padding: 32px 20px;
      text-align: center;
      cursor: pointer;
      transition: all .2s;
      background: var(--depth-3);
    }
    .drop-zone:hover, .drop-zone.over {
      border-color: var(--accent-blue);
      background: rgba(59,130,246,.06);
    }
    .drop-zone input { display: none; }
    .drop-icon { font-size: 36px; opacity: .3; margin-bottom: 10px; }
    .drop-title { font-size: 14px; font-weight: 700; color: var(--text-secondary); }
    .drop-sub   { font-size: 12px; color: var(--text-muted); margin-top: 4px; }

    /* Seção de formulário */
    .form-section {
      background: var(--depth-3);
      border: 1px solid var(--border-default);
      border-radius: var(--r-lg);
      overflow: hidden;
      margin-bottom: 14px;
    }
    .form-sec-hdr {
      padding: 11px 16px;
      border-bottom: 1px solid var(--border-subtle);
      display: flex; align-items: center; gap: 8px;
      font-weight: 700; font-size: 13px;
    }
    .form-sec-body { padding: 14px 16px; display: flex; flex-direction: column; gap: 12px; }

    /* Campos */
    .field { display: flex; flex-direction: column; gap: 4px; }
    .field label {
      font-size: 10px; font-weight: 700; color: var(--text-muted);
      text-transform: uppercase; letter-spacing: .4px;
      display: flex; align-items: center; gap: 5px;
    }
    .field-auto::after {
      content: 'AUTO'; font-size: 8px; background: rgba(16,185,129,.15);
      color: var(--accent-green); border: 1px solid rgba(16,185,129,.25);
      border-radius: 999px; padding: 1px 5px; font-weight: 700;
    }
    .field input, .field select, .field textarea {
      background: var(--depth-4);
      border: 1px solid var(--border-default);
      border-radius: var(--r-md);
      padding: 8px 10px;
      color: var(--text-primary);
      font-family: var(--font-body);
      font-size: 13px;
      outline: none;
      transition: border-color .15s;
    }
    .field input:focus, .field select:focus, .field textarea:focus {
      border-color: var(--accent-blue);
    }
    .field input.auto-filled {
      border-color: rgba(16,185,129,.4);
      background: rgba(16,185,129,.04);
    }
    .field textarea { min-height: 80px; resize: vertical; }
    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .field-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }

    /* Badge extraído */
    .badge-extraido {
      display: inline-flex; align-items: center; gap: 4px;
      background: rgba(16,185,129,.1); border: 1px solid rgba(16,185,129,.2);
      border-radius: 999px; padding: 2px 8px;
      font-size: 10px; font-weight: 700; color: var(--accent-green);
    }

    /* Preview painel direito */
    .preview-panel {
      position: sticky;
      top: 20px;
    }
    .preview-card {
      background: var(--depth-3);
      border: 1px solid var(--border-default);
      border-radius: var(--r-lg);
      overflow: hidden;
      margin-bottom: 14px;
    }
    .preview-hdr {
      padding: 11px 16px;
      border-bottom: 1px solid var(--border-subtle);
      font-weight: 700; font-size: 13px;
    }
    .preview-body { padding: 14px 16px; }
    .preview-nome { font-size: 15px; font-weight: 700; line-height: 1.3; margin-bottom: 6px; color: var(--text-primary); }
    .preview-sku  { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--accent-blue); font-weight: 700; }
    .preview-pills { display: flex; gap: 5px; flex-wrap: wrap; margin: 8px 0; }
    .pill { font-size: 9px; font-weight: 700; padding: 2px 6px; border-radius: 999px; }
    .pill-brand { background: rgba(168,85,247,.15); color: var(--accent-purple, #a855f7); border: 1px solid rgba(168,85,247,.2); }
    .pill-ean   { background: var(--depth-5); color: var(--text-muted); border: 1px solid var(--border-default); }
    .preview-dims {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; margin-top: 10px;
    }
    .dim-box {
      background: var(--depth-4); border-radius: var(--r-sm); padding: 7px 9px; text-align: center;
    }
    .dim-label { font-size: 9px; color: var(--text-muted); font-weight: 700; text-transform: uppercase; }
    .dim-val { font-family: 'Space Mono', monospace; font-size: 13px; font-weight: 700; margin-top: 2px; }

    /* Status de publicação */
    .status-bar {
      background: var(--depth-3);
      border: 1px solid var(--border-default);
      border-radius: var(--r-lg);
      padding: 14px 16px;
    }
    .status-step {
      display: flex; align-items: center; gap: 10px;
      padding: 7px 0;
      border-bottom: 1px solid var(--border-subtle);
      font-size: 13px;
    }
    .status-step:last-child { border-bottom: none; }
    .step-icon { width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; flex-shrink: 0; }
    .step-pending  { background: var(--depth-5); color: var(--text-muted); }
    .step-ok       { background: rgba(16,185,129,.15); color: var(--accent-green); }
    .step-err      { background: rgba(239,68,68,.15); color: var(--accent-red); }
    .step-loading  { background: rgba(59,130,246,.15); color: var(--accent-blue); animation: pulse .8s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

    /* Abas de entrada */
    .entrada-tab.active { background: var(--depth-3) !important; color: var(--text-primary) !important; }

    /* Campo obrigatório vazio */
    .field input.campo-obrigatorio:placeholder-shown {
      border-color: rgba(245,200,66,.4);
      background: rgba(245,200,66,.04);
    }
    /* Campo preenchido automaticamente */
    .field input.auto-ok, .field textarea.auto-ok, .field select.auto-ok {
      border-color: rgba(16,185,129,.35);
      background: rgba(16,185,129,.04);
      transition: border-color .4s, background .4s;
    }
    /* Campo obrigatório destacado */
    .field .req-dot {
      display:inline-block;width:5px;height:5px;background:var(--accent-yellow);
      border-radius:50%;margin-left:3px;vertical-align:middle;
    }

    /* Btn loading */
    .btn-loading { position: relative; pointer-events: none; opacity: .75; }
    .btn-loading::after {
      content: ''; position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
      width: 12px; height: 12px; border: 2px solid currentColor; border-top-color: transparent;
      border-radius: 50%; animation: spin .6s linear infinite;
    }
    @keyframes spin { to { transform: translateY(-50%) rotate(360deg); } }

    /* AI text generation area */
    .ai-box {
      background: rgba(59,130,246,.05);
      border: 1px solid rgba(59,130,246,.15);
      border-radius: var(--r-md);
      padding: 12px 14px;
    }
    .ai-box-title { font-size: 11px; font-weight: 700; color: var(--accent-blue); margin-bottom: 8px; display: flex; align-items: center; gap: 6px; }

    /* Extraction log */
    .log-item { font-size: 11px; color: var(--text-muted); padding: 3px 0; display: flex; gap: 6px; }
    .log-item.ok  { color: var(--accent-green); }
    .log-item.err { color: var(--accent-red); }
  </style>
  <script src="/auth-guard.js"></script>
</head>
<body>
<div class="erp-layout">
  <div id="sidebar-placeholder"></div>
  <main class="erp-main" style="overflow-y:auto;">

    <div class="page-header" style="padding:20px 20px 0;">
      <div>
        <h1 class="page-title">📦 Cadastrar Produto</h1>
        <p class="page-subtitle">Importe a ficha técnica da Dorel e publique no Bling com um clique</p>
      </div>
    </div>

    <div class="cad-layout">

      <!-- COLUNA ESQUERDA: formulário -->
      <div>

        <!-- Entrada PDF -->
        <div style="margin-bottom:16px;padding:10px 14px;background:var(--depth-3);border:1px solid var(--border-default);border-radius:var(--r-lg);">
          <span style="font-size:13px;font-weight:700;color:var(--text-primary);">📄 Importar ficha técnica (PDF)</span>
        </div>

        <!-- Painel PDF -->
        <div id="painelPdf">
          <label class="drop-zone" id="dropZone">
            <input type="file" id="pdfInput" accept=".pdf" />
            <div class="drop-icon">📄</div>
            <div class="drop-title">Arraste a ficha técnica PDF aqui</div>
            <div class="drop-sub">ou clique para selecionar — extração automática dos campos</div>
            <div id="dropStatus" style="margin-top:10px;display:none;"></div>
          </label>
          <div id="extractLog" style="display:none;background:var(--depth-3);border:1px solid var(--border-default);border-radius:var(--r-md);padding:10px 14px;margin-bottom:14px;font-size:11px;"></div>
        </div>



        <!-- Identificação -->
        <div class="form-section">
          <div class="form-sec-hdr">🏷️ Identificação</div>
          <div class="form-sec-body">
            <div class="field-row">
              <div class="field">
                <label class="field-auto">SKU / Código Totvs</label>
                <input type="text" id="fSku" placeholder="IMP02688" autocomplete="off"/>
              </div>
              <div class="field">
                <label class="field-auto">Marca</label>
                <input type="text" id="fMarca" placeholder="Tiny Love" autocomplete="off"/>
              </div>
            </div>
            <div class="field">
              <label class="field-auto">Nome completo do produto</label>
              <input type="text" id="fNome" placeholder="Arco Sunny Stroll Unicorn Wonderlands - Tiny Love" autocomplete="off"/>
            </div>
            <div class="field-row">
              <div class="field">
                <label class="field-auto">EAN (unitário)</label>
                <input type="text" id="fEan" placeholder="7908238813092" autocomplete="off"/>
              </div>
              <div class="field">
                <label class="field-auto">EAN Caixa master</label>
                <input type="text" id="fEanBox" placeholder="17908238813099 (se houver)" autocomplete="off"/>
              </div>
            </div>
            <div class="field-row">
              <div class="field">
                <label class="field-auto">NCM</label>
                <input type="text" id="fNcm" placeholder="95030099" autocomplete="off"/>
              </div>
              <div class="field">
                <label>Categoria Bling</label>
                <select id="fCategoria">
                  <option value="">— Selecionar —</option>
                </select>
              </div>
            </div>
            <div class="field-row">
              <div class="field">
                <label>Formato</label>
                <select id="fFormato">
                  <option value="S">Simples</option>
                  <option value="C">Com composição</option>
                </select>
              </div>
              <div class="field">
                <label>Preço de venda (R$)</label>
                <input type="number" id="fPreco" placeholder="219.00" step="0.01" min="0"/>
              </div>
            </div>
            <div class="field">
              <label>Tags (Grupo:X|Marca:Y|Modalidade:Z)</label>
              <input type="text" id="fTags" placeholder="Grupo:Brinquedos|Marca:Tiny Love|Modalidade:FULL" autocomplete="off"/>
            </div>
          </div>
        </div>

        <!-- Dimensões -->
        <div class="form-section">
          <div class="form-sec-hdr">📐 Dimensões e Peso</div>
          <div class="form-sec-body">
            <div class="field-row-3">
              <div class="field">
                <label class="field-auto">Altura (cm)</label>
                <input type="number" id="fAltura" placeholder="15" step="0.1" min="0"/>
              </div>
              <div class="field">
                <label class="field-auto">Largura (cm)</label>
                <input type="number" id="fLargura" placeholder="82" step="0.1" min="0"/>
              </div>
              <div class="field">
                <label class="field-auto">Profundidade (cm)</label>
                <input type="number" id="fProfundidade" placeholder="6" step="0.1" min="0"/>
              </div>
            </div>
            <div class="field-row">
              <div class="field">
                <label class="field-auto">Peso líquido (kg)</label>
                <input type="number" id="fPesoLiq" placeholder="0.395" step="0.001" min="0"/>
              </div>
              <div class="field">
                <label class="field-auto">Peso bruto (kg)</label>
                <input type="number" id="fPesoBruto" placeholder="0.96" step="0.001" min="0"/>
              </div>
            </div>
            <div class="field">
              <label>Itens por caixa master</label>
              <input type="number" id="fItensCx" placeholder="1" min="1" value="1"/>
            </div>
          </div>
        </div>

        <!-- Descrições -->
        <div class="form-section">
          <div class="form-sec-hdr">📝 Textos para anúncio</div>
          <div class="form-sec-body">
            <!-- Gerador IA -->
            <div class="ai-box">
              <div class="ai-box-title">✨ Gerar textos com IA</div>
              <div style="font-size:12px;color:var(--text-muted);margin-bottom:10px;">
                Preencha SKU e Nome primeiro, depois clique para gerar título otimizado e descrições para ML/Shopee.
              </div>
              <button class="btn btn-primary btn-sm" id="btnGerarTexto" data-action="gerar-ia" style="font-size:12px;">
                ✨ Gerar com IA
              </button>
            </div>
            <div class="field">
              <label class="field-auto">Descrição curta (aparece no topo do anúncio)</label>
              <textarea id="fDescCurta" placeholder="Será extraída da ficha técnica ou gerada por IA…" rows="3"></textarea>
            </div>
            <div class="field">
              <label class="field-auto">Descrição completa</label>
              <textarea id="fDescLonga" placeholder="Será extraída da ficha técnica ou gerada por IA…" rows="6"></textarea>
            </div>
          </div>
        </div>

      </div>

      <!-- COLUNA DIREITA: preview + publicar -->
      <div class="preview-panel">

        <!-- Preview card -->
        <div class="preview-card">
          <div class="preview-hdr">👁 Preview</div>
          <div class="preview-body">
            <div class="preview-sku" id="pvSku">SKU</div>
            <div class="preview-nome" id="pvNome">Nome do produto aparecerá aqui</div>
            <div class="preview-pills" id="pvPills"></div>
            <div class="preview-dims" id="pvDims">
              <div class="dim-box"><div class="dim-label">Altura</div><div class="dim-val" id="pvA">—</div></div>
              <div class="dim-box"><div class="dim-label">Largura</div><div class="dim-val" id="pvL">—</div></div>
              <div class="dim-box"><div class="dim-label">Profund.</div><div class="dim-val" id="pvP">—</div></div>
            </div>
            <div style="margin-top:10px;display:grid;grid-template-columns:1fr 1fr;gap:6px;">
              <div class="dim-box"><div class="dim-label">Peso líq.</div><div class="dim-val" id="pvPl" style="font-size:12px;">—</div></div>
              <div class="dim-box"><div class="dim-label">Peso bruto</div><div class="dim-val" id="pvPb" style="font-size:12px;">—</div></div>
            </div>
          </div>
        </div>

        <!-- Status passos -->
        <div class="status-bar" style="margin-bottom:14px;">
          <div class="status-step">
            <div class="step-icon step-pending" id="st1">1</div>
            <span id="st1txt">Preencher dados obrigatórios</span>
          </div>
          <div class="status-step">
            <div class="step-icon step-pending" id="st2">2</div>
            <span id="st2txt">Criar produto no Bling</span>
          </div>
          <div class="status-step">
            <div class="step-icon step-pending" id="st3">3</div>
            <span id="st3txt">Salvar no sistema</span>
          </div>
        </div>

        <!-- Botão publicar -->
        <button class="btn btn-primary" id="btnPublicar" data-action="publicar" style="width:100%;font-size:14px;padding:12px;margin-bottom:10px;">
          🚀 Cadastrar e publicar no Bling
        </button>
        <button class="btn btn-secondary" id="btnSalvarLocal" data-action="salvar-local" style="width:100%;font-size:13px;padding:10px;">
          💾 Salvar só no sistema (sem Bling)
        </button>

        <!-- Resultado -->
        <div id="resultBox" style="display:none;margin-top:12px;"></div>

      </div>
    </div>

  </main>
</div>

<div class="toast" id="toast"></div>
<script src="/menu.js"></script>

<!-- pdf.js para extração -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script>
'use strict';

// Configura worker do pdf.js
if(typeof pdfjsLib !== 'undefined'){
  pdfjsLib.GlobalWorkerOptions.workerSrc =
    'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
}

const TERMINAL_KEY = 'expedicao_pro_terminal_id';
function tid(){let i=localStorage.getItem(TERMINAL_KEY);if(!i){i=crypto.randomUUID();localStorage.setItem(TERMINAL_KEY,i);}return i;}

async function api(path,opts={}){
  const token=localStorage.getItem('expedicao_token')||'';
  const res=await fetch(path,{...opts,headers:{'content-type':'application/json','x-terminal-id':tid(),'authorization':`Bearer ${token}`,...(opts.headers||{})}});
  const d=await res.json().catch(()=>({}));
  if(res.status===401){window.location.href='/login';return null;}
  if(!res.ok)throw new Error(d.error||`HTTP ${res.status}`);
  return d;
}
function esc(s){return(s??'').toString().replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'})[m]);}

let _tt=null;
function toast(msg,type='info'){
  const el=document.getElementById('toast');
  el.textContent=msg;el.className=`toast show ${type}`;
  clearTimeout(_tt);_tt=setTimeout(()=>el.classList.remove('show'),3000);
}

// ── Carregar categorias do Bling ──────────────────────────────────────────
async function carregarCategorias(){
  try{
    const d=await api('/produtos/categorias-bling');
    if(!d?.items?.length)return;
    const sel=document.getElementById('fCategoria');
    d.items.forEach(c=>{
      const opt=document.createElement('option');
      opt.value=c.nome;opt.textContent=c.nome;
      sel.appendChild(opt);
    });
  }catch(e){console.warn('Categorias Bling não disponíveis:',e.message);}
}

// ── Extração do PDF ───────────────────────────────────────────────────────
document.getElementById('pdfInput').addEventListener('change',function(){
  if(this.files?.length)processarPDF(this.files[0]);
});

const dropZone=document.getElementById('dropZone');
dropZone.addEventListener('dragover',e=>{e.preventDefault();dropZone.classList.add('over');});
dropZone.addEventListener('dragleave',()=>dropZone.classList.remove('over'));
dropZone.addEventListener('drop',e=>{
  e.preventDefault();dropZone.classList.remove('over');
  const file=e.dataTransfer.files[0];
  if(file?.name.endsWith('.pdf'))processarPDF(file);
});

async function processarPDF(file){
  const status=document.getElementById('dropStatus');
  const logEl=document.getElementById('extractLog');
  status.style.display='block';
  status.innerHTML='<span style="color:var(--accent-blue);font-size:12px;">🔍 Extraindo dados…</span>';
  logEl.style.display='none';logEl.innerHTML='';

  try{
    const arrayBuffer=await file.arrayBuffer();
    const pdf=await pdfjsLib.getDocument({data:arrayBuffer}).promise;

    let fullText='';
    for(let i=1;i<=pdf.numPages;i++){
      const page=await pdf.getPage(i);
      const content=await page.getTextContent();
      fullText+=content.items.map(item=>item.str).join(' ')+'\n';
    }

    const campos=extrairCampos(fullText);
    preencherFormulario(campos);

    const extraidos=Object.keys(campos).filter(k=>campos[k]);
    status.innerHTML=`<span style="color:var(--accent-green);font-size:12px;">✓ ${extraidos.length} campos extraídos automaticamente</span>`;
    logEl.style.display='block';
    logEl.innerHTML=`<div style="font-weight:700;color:var(--text-secondary);margin-bottom:6px;">Log de extração — ${esc(file.name)}</div>`
      +extraidos.map(k=>`<div class="log-item ok">✓ ${esc(k)}: <strong>${esc(String(campos[k]).slice(0,60))}</strong></div>`).join('');

    toast('PDF extraído com sucesso!','ok');
  }catch(e){
    status.innerHTML=`<span style="color:var(--accent-red);font-size:12px;">Erro: ${esc(e.message)}</span>`;
    toast('Erro ao processar PDF: '+e.message,'err');
  }
}

// ── Parser do texto do PDF ────────────────────────────────────────────────
function extrairCampos(texto){
  const t=texto.replace(/\s+/g,' ');
  const campos={};

  // ── Marca ────────────────────────────────────────────────────────────────
  // Prioridade 1: sufixo " - Marca Nome" no título (ex: "Booster Moon Fix - Cosco Kids")
  const marcaSufixo=t.match(/\b(?:Safety\s*1st|Tiny\s*Love|Cosco\s*Kids?|Buba|Maxi-Cosi|Chicco|Tutti\s*Baby|Vittak)/i);
  if(marcaSufixo) campos.marca=marcaSufixo[0].trim();

  // ── Nome do produto ───────────────────────────────────────────────────────
  // Padrão: "NomeProduto - Marca" no início, antes de subcategoria ou "novo"
  // Captura tudo antes do traço + marca, ou antes de palavras-chave de layout
  const nomeMatch=t.match(/^([\w\sÀ-ÿ\-\/]+?)\s*-\s*(?:Safety\s*1st|Tiny\s*Love|Cosco\s*Kids?|Buba|Maxi-Cosi|Chicco|Tutti\s*Baby|Vittak)/i);
  if(nomeMatch) campos.nome=nomeMatch[1].trim();
  else {
    // Fallback: texto antes de "Cadeira|Carrinho|Bebê|Acessório|novo|Preço"
    const nomeFallback=t.match(/^([\w\sÀ-ÿ\-\/]+?)\s+(?:Cadeira|Carrinho|Bebê|Acessório|Brinquedo|novo|Preço)/i);
    if(nomeFallback) campos.nome=nomeFallback[1].trim();
  }

  // ── SKU / Totvs ───────────────────────────────────────────────────────────
  // Padrão tabela SKU: "novo IMP02509 7908..." — pega o código Totvs na coluna
  const skuMatch=t.match(/(?:Totvs|novo|usado)\s+([A-Z]{2,4}\d{4,8})\s+\d{13}/);
  if(skuMatch) campos.sku=skuMatch[1];
  else {
    // Fallback: qualquer menção explícita de Totvs
    const skuFallback=t.match(/Totvs[^\w]*([A-Z]{2,4}\d{4,8})/);
    if(skuFallback) campos.sku=skuFallback[1];
  }

  // ── EAN unitário (13 dígitos, não começa com 17) ─────────────────────────
  const eans=[];
  const eanReg=/\b(\d{13})\b/g;
  let m;
  while((m=eanReg.exec(t))!==null){
    if(!m[1].startsWith('17'))eans.push(m[1]);
  }
  if(eans.length>0)campos.ean=eans[0];

  // ── EAN caixa (começa com 17) ─────────────────────────────────────────────
  const eanBoxMatch=t.match(/\b(17\d{12})\b/);
  if(eanBoxMatch)campos.eanBox=eanBoxMatch[1];

  // ── NCM ───────────────────────────────────────────────────────────────────
  const ncmMatch=t.match(/NCM\s*(\d{8})/);
  if(ncmMatch)campos.ncm=ncmMatch[1];

  // ── Dimensões ─────────────────────────────────────────────────────────────
  // O PDF pode ter quebras de linha dentro do padrão, por isso usamos [\s\S] e normalizamos
  const tNorm = t.replace(/\r?\n/g, ' ').replace(/\s+/g, ' '); // texto numa linha só para regex

  function parseDims(a,l,p){
    return {
      altura:       parseFloat(a.replace(',','.')),
      largura:      parseFloat(l.replace(',','.')),
      profundidade: parseFloat(p.replace(',','.')),
    };
  }
  const NUM='([\\d,.]+)';
  const SEP='\\s*[xX×]\\s*';

  // 1. Medidas da EMBALAGEM — "Medidas (A x L x P) 44 x 40 x 20 cm"
  const dimsEmbMatch = tNorm.match(
    new RegExp(`Medidas?\\s*\\(A\\s*[xX]\\s*L\\s*[xX]\\s*P[^)]*\\)\\s*${NUM}${SEP}${NUM}${SEP}${NUM}`,'i')
  );
  if(dimsEmbMatch){
    const d=parseDims(dimsEmbMatch[1],dimsEmbMatch[2],dimsEmbMatch[3]);
    if(d.altura && d.largura && d.profundidade){
      campos.altura=d.altura; campos.largura=d.largura; campos.profundidade=d.profundidade;
    }
  }

  // 2. Fallback: Dimensões EXTERNAS — "Dimensões Externa do Produto (A x L x P | cm) 22 x 43,5 x 42,5"
  //    Aceita pipe (|) e quebra entre o parêntese e os números
  if(!campos.altura){
    const dimsProdMatch = tNorm.match(
      new RegExp(`Dimens[oõ]es?\\s+Externa[^(]*?\\([^)]*\\)\\s*${NUM}${SEP}${NUM}${SEP}${NUM}`,'i')
    );
    if(dimsProdMatch){
      const d=parseDims(dimsProdMatch[1],dimsProdMatch[2],dimsProdMatch[3]);
      if(d.altura && d.largura && d.profundidade){
        campos.altura=d.altura; campos.largura=d.largura; campos.profundidade=d.profundidade;
      }
    }
  }

  // 3. Fallback genérico — qualquer "N x N x N cm" no texto
  if(!campos.altura){
    const genericMatch = tNorm.match(new RegExp(`${NUM}${SEP}${NUM}${SEP}${NUM}\\s*cm`,'i'));
    if(genericMatch){
      const d=parseDims(genericMatch[1],genericMatch[2],genericMatch[3]);
      if(d.altura>0 && d.largura>0 && d.profundidade>0){
        campos.altura=d.altura; campos.largura=d.largura; campos.profundidade=d.profundidade;
      }
    }
  }

  // ── Peso líquido — "Peso do Produto 2 kg" ────────────────────────────────
  const pesoMatch=tNorm.match(/Peso\s+do\s+Produto\s*([\d,.]+)\s*(g|kg)?/i);
  if(pesoMatch){
    let p=parseFloat(pesoMatch[1].replace(',','.'));
    const u=(pesoMatch[2]||'').toLowerCase();
    if(u==='g'||(!u&&p>10)) p=p/1000;
    campos.pesoLiquido=+p.toFixed(3);
  }

  // ── Peso bruto — "Peso (Bruto) 2.3 kg" ───────────────────────────────────
  const pesoBrutoMatch=tNorm.match(/Peso\s*\(?\s*Bruto\s*\)?\s*([\d,.]+)\s*(g|kg)?/i);
  if(pesoBrutoMatch){
    let pb=parseFloat(pesoBrutoMatch[1].replace(',','.'));
    const u=(pesoBrutoMatch[2]||'').toLowerCase();
    if(u==='g'||(!u&&pb>20)) pb=pb/1000;
    campos.pesoBruto=+pb.toFixed(3);
  }

  // ── Itens por caixa ───────────────────────────────────────────────────────
  // Tabela SKU: coluna "Qtd." antes de "Filial" — pega o número entre Cor e final da linha
  const itensCxMatch=t.match(/\d{13}\s+[\w\s]+\s+(\d+)\s+\d+\s*(?:$|Especifica)/);
  if(itensCxMatch){
    const n=parseInt(itensCxMatch[1]);
    if(n>1)campos.itensCaixa=n;
  }

  // ── Preço anunciado ───────────────────────────────────────────────────────
  const precoMatch=t.match(/Preço\s+Anunciado[:\s]*R\$\s*([\d,.]+)/i);
  if(precoMatch){
    const pv=parseFloat(precoMatch[1].replace('.','').replace(',','.'));
    if(pv>0)campos.preco=pv;
  }

  // ── Descrição curta (primeira frase da Descrição Completa) ───────────────
  const descMatch=t.match(/Descrição\s+Completa\s+([^.!?]{20,}[.!?])/i);
  if(descMatch)campos.descCurta=descMatch[1].trim().slice(0,180);

  // ── Descrição longa ───────────────────────────────────────────────────────
  const descLongaMatch=t.match(/Descrição\s+Completa\s+([\s\S]+?)(?:\bSKU\b|\bEspecifica)/i);
  if(descLongaMatch){
    campos.descLonga=descLongaMatch[1].replace(/\s+/g,' ').trim().slice(0,2000);
  }

  return campos;
}

// ── Preencher formulário com campos extraídos ─────────────────────────────
function preencherFormulario(c){
  const setVal=(id,val)=>{
    if(val===undefined||val===null||val==='')return;
    const el=document.getElementById(id);
    if(!el)return;
    el.value=val;
    el.classList.add('auto-filled');
    setTimeout(()=>el.classList.remove('auto-filled'),3000);
  };
  setVal('fSku',      c.sku);
  setVal('fMarca',    c.marca);
  setVal('fNome',     c.nome);
  setVal('fEan',      c.ean);
  setVal('fEanBox',   c.eanBox);
  setVal('fNcm',      c.ncm);
  setVal('fAltura',   c.altura);
  setVal('fLargura',  c.largura);
  setVal('fProfundidade', c.profundidade);
  setVal('fPesoLiq',  c.pesoLiquido);
  setVal('fPesoBruto',c.pesoBruto);
  setVal('fItensCx',  c.itensCaixa);
  setVal('fPreco',    c.preco);
  setVal('fDescCurta',c.descCurta);
  setVal('fDescLonga',c.descLonga);
  atualizarPreview();
}

// ── Preview em tempo real ─────────────────────────────────────────────────
function atualizarPreview(){
  document.getElementById('pvSku').textContent   = document.getElementById('fSku').value   || 'SKU';
  document.getElementById('pvNome').textContent  = document.getElementById('fNome').value  || 'Nome do produto aparecerá aqui';
  document.getElementById('pvA').textContent     = (document.getElementById('fAltura').value      ||'—') + (document.getElementById('fAltura').value?'cm':'');
  document.getElementById('pvL').textContent     = (document.getElementById('fLargura').value     ||'—') + (document.getElementById('fLargura').value?'cm':'');
  document.getElementById('pvP').textContent     = (document.getElementById('fProfundidade').value||'—') + (document.getElementById('fProfundidade').value?'cm':'');
  document.getElementById('pvPl').textContent    = (document.getElementById('fPesoLiq').value     ||'—') + (document.getElementById('fPesoLiq').value?'kg':'');
  document.getElementById('pvPb').textContent    = (document.getElementById('fPesoBruto').value   ||'—') + (document.getElementById('fPesoBruto').value?'kg':'');

  // Pills
  const pills=[];
  const marca=document.getElementById('fMarca').value;
  const ean  =document.getElementById('fEan').value;
  if(marca)pills.push(`<span class="pill pill-brand">${esc(marca)}</span>`);
  if(ean)  pills.push(`<span class="pill pill-ean">EAN ${esc(ean)}</span>`);
  document.getElementById('pvPills').innerHTML=pills.join('');

  // Status passo 1
  const nome=document.getElementById('fNome').value;
  const sku =document.getElementById('fSku').value;
  const st1 =document.getElementById('st1');
  const st1t=document.getElementById('st1txt');
  if(nome&&sku&&marca){
    st1.className='step-icon step-ok';st1.textContent='✓';
    st1t.textContent='Dados obrigatórios preenchidos';
  }else{
    st1.className='step-icon step-pending';st1.textContent='1';
    st1t.textContent='Preencher nome, SKU e marca';
  }
}

// Bind preview em tempo real
['fSku','fMarca','fNome','fEan','fAltura','fLargura','fProfundidade','fPesoLiq','fPesoBruto'].forEach(id=>{
  document.getElementById(id)?.addEventListener('input',atualizarPreview);
});

// ── Gerar textos com IA ───────────────────────────────────────────────────
async function gerarTextoIA(){
  const nome   = document.getElementById('fNome').value.trim();
  const marca  = document.getElementById('fMarca').value.trim();
  const sku    = document.getElementById('fSku').value.trim();
  const dims   = `${document.getElementById('fAltura').value||'?'}×${document.getElementById('fLargura').value||'?'}×${document.getElementById('fProfundidade').value||'?'}cm`;
  const peso   = document.getElementById('fPesoLiq').value;
  const descAt = document.getElementById('fDescLonga').value.trim();

  if(!nome||!marca){toast('Preencha nome e marca antes de gerar','err');return;}

  const btn=document.getElementById('btnGerarTexto');
  btn.classList.add('btn-loading');btn.disabled=true;

  try{
    const prompt=`Você é especialista em criar anúncios para marketplace brasileiro (Mercado Livre e Shopee).

Produto: ${nome}
Marca: ${marca}
SKU: ${sku}
Dimensões: ${dims}
Peso: ${peso||'não informado'}kg
Descrição original da fabricante: ${descAt||'não disponível'}

Gere em JSON (sem markdown):
{
  "descricaoCurta": "Uma frase impactante de até 120 caracteres para o topo do anúncio",
  "descricaoLonga": "Descrição completa em português brasileiro, 3-4 parágrafos com benefícios, público-alvo, diferenciais. Termine com bullet points dos principais atributos técnicos.",
  "tituloML": "Título otimizado para Mercado Livre (máximo 60 caracteres, inclui marca e modelo)",
  "tituloShopee": "Título otimizado para Shopee (máximo 100 caracteres)"
}`;

    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        messages:[{role:'user',content:prompt}]
      })
    });
    const data=await res.json();
    const raw=data.content?.[0]?.text||'';
    const clean=raw.replace(/```json|```/g,'').trim();
    const parsed=JSON.parse(clean);

    if(parsed.descricaoCurta)document.getElementById('fDescCurta').value=parsed.descricaoCurta;
    if(parsed.descricaoLonga)document.getElementById('fDescLonga').value=parsed.descricaoLonga;

    // Mostra títulos gerados
    if(parsed.tituloML||parsed.tituloShopee){
      toast('Textos gerados! Títulos: ML: '+parsed.tituloML,'ok');
    }
    toast('Textos gerados com IA ✓','ok');
  }catch(e){
    toast('Erro ao gerar texto: '+e.message,'err');
  }finally{
    btn.classList.remove('btn-loading');btn.disabled=false;
  }
}

// ── Coletar dados do formulário ───────────────────────────────────────────
function coletarDados(){
  return {
    sku:          document.getElementById('fSku').value.trim().toUpperCase(),
    nome:         document.getElementById('fNome').value.trim(),
    marca:        document.getElementById('fMarca').value.trim(),
    ean:          document.getElementById('fEan').value.trim(),
    eanBox:       document.getElementById('fEanBox').value.trim(),
    ncm:          document.getElementById('fNcm').value.trim(),
    categoria:    document.getElementById('fCategoria').value,
    formato:      document.getElementById('fFormato').value,
    preco:        parseFloat(document.getElementById('fPreco').value)  || 0,
    altura:       parseFloat(document.getElementById('fAltura').value) || 0,
    largura:      parseFloat(document.getElementById('fLargura').value)|| 0,
    profundidade: parseFloat(document.getElementById('fProfundidade').value) || 0,
    pesoLiquido:  parseFloat(document.getElementById('fPesoLiq').value)  || 0,
    pesoBruto:    parseFloat(document.getElementById('fPesoBruto').value) || 0,
    itensPorCaixa: parseInt(document.getElementById('fItensCx').value) || 1,
    tagsRaw:      document.getElementById('fTags').value.trim(),
    descricaoCurta: document.getElementById('fDescCurta').value.trim(),
    descricaoLonga: document.getElementById('fDescLonga').value.trim(),
    mlFotos:      [],
    mlbIdOrigem:  null,
  };
}

function validar(d){
  if(!d.nome)return'Nome obrigatório';
  if(!d.sku) return'SKU obrigatório';
  if(!d.marca)return'Marca obrigatória';
  return null;
}

async function publicar(){
  const d=coletarDados();
  const err=validar(d);
  if(err){toast(err,'err');return;}

  const btn=document.getElementById('btnPublicar');
  btn.classList.add('btn-loading');btn.disabled=true;

  setStep(2,'loading','Criando no Bling…');
  setStep(3,'pending','Aguardando…');

  try{
    const res=await api('/produtos/cadastrar',{method:'POST',body:JSON.stringify(d)});
    if(!res)throw new Error('Sem resposta do servidor');

    setStep(2, res.blingId?'ok':'err',
      res.blingId?`Bling ✓ (id: ${res.blingId})`:'Bling falhou — salvo localmente');
    setStep(3,'ok','Salvo no sistema ✓');

    mostrarResultado(res);
    toast(res.blingId?'Produto criado no Bling ✓':'Produto salvo no sistema','ok');
  }catch(e){
    setStep(2,'err','Erro: '+e.message);
    toast('Erro: '+e.message,'err');
  }finally{
    btn.classList.remove('btn-loading');btn.disabled=false;
  }
}

async function salvarSomenteLocal(){
  const d=coletarDados();
  const err=validar(d);
  if(err){toast(err,'err');return;}
  const btn=document.getElementById('btnSalvarLocal');
  btn.classList.add('btn-loading');btn.disabled=true;
  try{
    const res=await api('/produtos/cadastrar',{method:'POST',body:JSON.stringify({...d,_skipBling:true})});
    setStep(3,'ok','Salvo no sistema ✓');
    mostrarResultado(res);
    toast('Produto salvo no sistema','ok');
  }catch(e){toast('Erro: '+e.message,'err');}
  finally{btn.classList.remove('btn-loading');btn.disabled=false;}
}

function setStep(n,state,txt){
  const icon=document.getElementById(`st${n}`);
  const label=document.getElementById(`st${n}txt`);
  icon.className='step-icon step-'+state;
  icon.textContent=state==='ok'?'✓':state==='err'?'✗':state==='loading'?'…':String(n);
  label.textContent=txt;
}

function novoCadastro(){
  ['fSku','fMarca','fNome','fEan','fEanBox','fNcm','fPreco','fAltura','fLargura','fProfundidade','fPesoLiq','fPesoBruto','fTags','fDescCurta','fDescLonga']
    .forEach(id=>{ const el=document.getElementById(id); if(el)el.value=''; });
  document.getElementById('fItensCx').value='1';
  document.getElementById('resultBox').style.display='none';
  document.getElementById('extractLog').style.display='none';
  document.getElementById('dropStatus').style.display='none';
  [2,3].forEach(n=>setStep(n,'pending',n===2?'Criar produto no Bling':'Salvar no sistema'));
  atualizarPreview();
  window.scrollTo({top:0,behavior:'smooth'});
}

function mostrarResultado(res){
  const box=document.getElementById('resultBox');
  box.style.display='block';
  box.innerHTML=`
    <div style="background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.2);border-radius:var(--r-md);padding:14px 16px;">
      <div style="font-weight:700;color:var(--accent-green);margin-bottom:6px;">✓ ${esc(res.sku)} cadastrado</div>
      <div style="font-size:12px;color:var(--text-muted);">${esc(res.mensagem)}</div>
      ${res.blingId?`<div style="font-size:11px;color:var(--text-muted);margin-top:4px;font-family:'Space Mono',monospace;">Bling ID: ${esc(String(res.blingId))}</div>`:''}
      <div style="display:flex;gap:8px;margin-top:12px;flex-wrap:wrap;">
        <a href="/admin?sku=${encodeURIComponent(res.sku)}" class="btn btn-primary btn-sm" style="font-size:12px;">Adicionar fotos no Admin →</a>
        <a href="/catalogo" class="btn btn-secondary btn-sm" style="font-size:12px;">Ver no Catálogo</a>
        <button class="btn btn-secondary btn-sm" id="btnNovoCadastro" style="font-size:12px;">+ Novo produto</button>
      </div>
    </div>`;
  document.getElementById('btnNovoCadastro').addEventListener('click', novoCadastro);
}

// ── Bind de eventos via addEventListener (sem inline onclick) ─────────────────
document.getElementById('btnGerarTexto').addEventListener('click', gerarTextoIA);
document.getElementById('btnPublicar').addEventListener('click', publicar);
document.getElementById('btnSalvarLocal').addEventListener('click', salvarSomenteLocal);

// ── Campos obrigatórios com placeholder amarelo ───────────────────────────────
const CAMPOS_OBRIGATORIOS = ['fSku','fMarca','fNome'];
const CAMPOS_IMPORTANTES  = ['fEan','fAltura','fLargura','fProfundidade','fPesoLiq'];

function marcarCamposObrigatorios(){
  CAMPOS_OBRIGATORIOS.forEach(id=>{
    const el=document.getElementById(id);
    if(el){
      el.classList.add('campo-obrigatorio');
      if(!el.placeholder) el.placeholder='Obrigatório';
    }
  });
}

// Override preencherFormulario para adicionar auto-ok visual
const _preencherOrig = preencherFormulario;
preencherFormulario = function(c){
  _preencherOrig(c);
  // Adiciona classe auto-ok temporariamente nos campos preenchidos
  const mapa = {sku:'fSku',marca:'fMarca',nome:'fNome',ean:'fEan',eanBox:'fEanBox',
    ncm:'fNcm',altura:'fAltura',largura:'fLargura',profundidade:'fProfundidade',
    pesoLiquido:'fPesoLiq',pesoBruto:'fPesoBruto',preco:'fPreco',
    descCurta:'fDescCurta',descLonga:'fDescLonga'};
  Object.entries(c).forEach(([k,v])=>{
    if(!v&&v!==0)return;
    const id=mapa[k];if(!id)return;
    const el=document.getElementById(id);
    if(!el)return;
    el.classList.add('auto-ok');
    setTimeout(()=>el.classList.remove('auto-ok'),4000);
  });
};

// ── Init ──────────────────────────────────────────────────────────────────
carregarCategorias();
atualizarPreview();
marcarCamposObrigatorios();
</script>
