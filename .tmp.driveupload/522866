// ── Marcas ─────────────────────────────────────────────────────────────────
const marcasAdmin=(()=>{
  let _todos=[],_visiveis=[],_marcasList=[],_pagAtual=0,_filtro='',_carregou=false;
  const POR_PAGINA=20;

  async function init(){
    if(_carregou)return;
    await Promise.all([_carregarProdutos(),_carregarMarcas()]);
    _carregou=true;
  }

  async function reload(){
    _todos=[];_visiveis=[];_marcasList=[];_pagAtual=0;_filtro='';_carregou=false;
    document.getElementById('marcasSearch').value='';
    document.getElementById('marcasList').innerHTML='';
    document.getElementById('marcasLoading').style.display='';
    document.getElementById('marcasEmpty').style.display='none';
    document.getElementById('marcasPag').style.display='none';
    await init();
  }

  async function _carregarProdutos(){
    try{
      const d=await api('/products/sem-marca?limit=500&offset=0');
      if(!d)return;
      _todos=d.items||[];
      _atualizarContador(_todos.length);
      _aplicarFiltro();
    }catch(e){toast('Erro ao carregar: '+e.message,'err');}
    finally{document.getElementById('marcasLoading').style.display='none';}
  }

  async function _carregarMarcas(){
    try{
      const d=await api('/products/marcas-list');
      if(d){_marcasList=d.items||[];_marcasListGlobal=_marcasList;}
    }catch(e){console.error('[marcas]',e.message);}
  }

  function filtrar(v){_filtro=v.toLowerCase();_pagAtual=0;_aplicarFiltro();}

  function _aplicarFiltro(){
    let lista=_filtro
      ?_todos.filter(p=>p.name.toLowerCase().includes(_filtro)||p.sku.toLowerCase().includes(_filtro))
      :[..._todos];
    lista.sort((a,b)=>(a.name||'').localeCompare(b.name||'','pt-BR'));
    _visiveis=lista;
    _renderizar();
  }

  function _renderizar(){
    const list=document.getElementById('marcasList');
    const empty=document.getElementById('marcasEmpty');
    const pag=document.getElementById('marcasPag');
    if(!_visiveis.length){list.innerHTML='';empty.style.display='';pag.style.display='none';return;}
    empty.style.display='none';
    const inicio=_pagAtual*POR_PAGINA;
    list.innerHTML=_visiveis.slice(inicio,inicio+POR_PAGINA).map(p=>_cardHTML(p)).join('');
    list.querySelectorAll('.btn-ok').forEach(btn=>btn.addEventListener('click',()=>salvar(btn.dataset.sku)));
    list.querySelectorAll('.btn-del').forEach(btn=>btn.addEventListener('click',()=>deletar(btn.dataset.sku)));
    list.querySelectorAll('.marca-sel').forEach(sel=>sel.addEventListener('change',()=>{
      const nova=document.getElementById('mnova-'+sel.dataset.sku);
      if(nova){nova.style.display=sel.value==='__nova__'?'':'none';if(sel.value!=='__nova__')nova.value='';}
    }));
    const totalPags=Math.ceil(_visiveis.length/POR_PAGINA);
    if(totalPags>1){
      pag.style.display='flex';
      document.getElementById('marcasPagInfo').textContent=(_pagAtual+1)+' / '+totalPags+'  ('+_visiveis.length+')';
      document.getElementById('marcasPrev').disabled=_pagAtual===0;
      document.getElementById('marcasNext').disabled=_pagAtual>=totalPags-1;
    }else{pag.style.display='none';}
  }

  function _cardHTML(p){
    const img=p.displayImage||'/assets/placeholder.png';
    const opts=_marcasList.map(m=>'<option value="'+esc(m.marca)+'">'+esc(m.marca)+'</option>').join('');
    const d='data-sku="'+esc(p.sku)+'"';
    return '<div class="marca-card" id="mc-'+esc(p.sku)+'">'
      +'<div class="marca-card-top">'
        +'<img class="marca-thumb" src="'+esc(img)+'" onerror="this.src=\'/assets/placeholder.png\';" alt="">'
        +'<div class="marca-info">'
          +'<div class="marca-name" title="'+esc(p.name)+'">'+esc(p.name)+'</div>'
          +'<div class="marca-sku">'+esc(p.sku)+'</div>'
        +'</div>'
        +'<button class="btn-del" '+d+' title="Deletar" style="margin-left:auto;background:none;border:none;cursor:pointer;font-size:13px;color:var(--accent-red);opacity:.5;padding:2px 4px;">✕</button>'
      +'</div>'
      +'<div class="marca-controls">'
        +'<select class="marca-sel" '+d+'>'
          +'<option value="">— marca —</option>'
          +'<option value="__nova__">+ Nova…</option>'
          +'<optgroup label="Cadastradas">'+opts+'</optgroup>'
        +'</select>'
        +'<input class="marca-nova-input" id="mnova-'+esc(p.sku)+'" type="text" placeholder="Nova marca" autocomplete="off">'
        +'<button class="btn btn-primary btn-sm btn-ok" '+d+' style="font-size:11px;padding:4px 8px;">OK</button>'
      +'</div>'
    +'</div>';
  }

  async function salvar(sku){
    const sel=list_querySelector('.marca-sel[data-sku]',sku);
    const nova=document.getElementById('mnova-'+sku);
    const marca=sel?.value==='__nova__'?(nova?.value||'').trim():(sel?.value||'').trim();
    if(!marca){toast('Selecione ou digite uma marca','err');return;}
    const btn=list_querySelector('.btn-ok[data-sku]',sku);
    if(btn){btn.disabled=true;btn.textContent='…';}
    try{
      await api('/products/'+encodeURIComponent(sku)+'/marca',{method:'PATCH',body:JSON.stringify({marca})});
      toast('"'+marca+'" salva ✓','ok');
      if(sel?.value==='__nova__'&&!_marcasList.find(m=>m.marca===marca))_marcasList.unshift({marca,count:1});
      const card=document.getElementById('mc-'+sku);
      if(card){
        card.style.transition='opacity .2s';card.style.opacity='0';
        setTimeout(()=>{
          _todos=_todos.filter(p=>p.sku!==sku);
          _visiveis=_visiveis.filter(p=>p.sku!==sku);
          _atualizarContador(_todos.length);
          const tp=Math.ceil(_visiveis.length/POR_PAGINA);
          if(_pagAtual>=tp&&_pagAtual>0)_pagAtual--;
          _renderizar();
        },220);
      }
    }catch(e){
      toast('Erro: '+e.message,'err');
      if(btn){btn.disabled=false;btn.textContent='OK';}
    }
  }

  async function deletar(sku){
    if(!confirm('Deletar "'+sku+'" permanentemente?'))return;
    try{
      await api('/products/'+encodeURIComponent(sku),{method:'DELETE'});
      toast(sku+' deletado','ok');
      _todos=_todos.filter(p=>p.sku!==sku);
      _visiveis=_visiveis.filter(p=>p.sku!==sku);
      _atualizarContador(_todos.length);
      const tp=Math.ceil(_visiveis.length/POR_PAGINA);
      if(_pagAtual>=tp&&_pagAtual>0)_pagAtual--;
      _renderizar();
    }catch(e){toast('Erro ao deletar: '+e.message,'err');}
  }

  // Helper seguro para querySelector com SKU que pode ter caracteres especiais
  function list_querySelector(baseSelector,sku){
    const list=document.getElementById('marcasList');
    if(!list)return null;
    return [...list.querySelectorAll(baseSelector)].find(el=>el.dataset.sku===sku)||null;
  }

  function proximaPagina(){const t=Math.ceil(_visiveis.length/POR_PAGINA);if(_pagAtual<t-1){_pagAtual++;_renderizar();_scrollTopo();}}
  function paginaAnterior(){if(_pagAtual>0){_pagAtual--;_renderizar();_scrollTopo();}}

  function _atualizarContador(n){
    const cnt=document.getElementById('marcasCounter');
    const badge=document.getElementById('badgeSemMarca');
    if(cnt){cnt.style.display=n>0?'':'none';cnt.textContent=n>0?n+' sem marca':'';}
    if(badge){badge.style.display=n>0?'':'none';badge.textContent=n>0?String(n):'';}
  }

  function _scrollTopo(){document.getElementById('marcasListWrap')?.scrollTo({top:0,behavior:'smooth'});}

  document.getElementById('marcasPrev').addEventListener('click',paginaAnterior);
  document.getElementById('marcasNext').addEventListener('click',proximaPagina);

  return{init,reload,filtrar,salvar,deletar,proximaPagina,paginaAnterior};
})();

window.marcasAdmin=marcasAdmin;
window.switchLeftTab=switchLeftTab;
window.saveBin=saveBin;window.saveNotes=saveNotes;
window.uploadPhoto=uploadPhoto;window.deletePhoto=deletePhoto;
window.abrirModalMarca=abrirModalMarca;window.fecharModalMarca=fecharModalMarca;window.salvarMarcaModal=salvarMarcaModal;
window.navProduto=navProduto;window.clearSearch=clearSearch;window.toggleFilter=toggleFilter;

loadEmbalagens();

// Auto-seleciona produto via ?sku= na URL (link do catálogo)
(()=>{
  const sku = new URLSearchParams(window.location.search).get('sku');
  if(sku){
    switchLeftTab('produtos');
    selectProduct(decodeURIComponent(sku));
  }
})();
</script>
