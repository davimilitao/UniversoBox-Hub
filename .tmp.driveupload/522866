function pc(url,kind,idx){return `<div class="photo-card"><img src="${esc(url)}" onerror="this.src='/assets/placeholder.png'" alt=""><div class="photo-overlay"><button class="photo-del" onclick="deletePhoto('${esc(kind)}',${idx})">✕</button></div></div>`;}
