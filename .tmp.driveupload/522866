// ── Upload foto ────────────────────────────────────────────────────────────
async function uploadPhoto(kind,input){
  if(!currentSku||!input.files?.length)return;
  const label=input.closest('label');
  if(label)label.classList.add('photo-uploading');
  const formData=new FormData();
  formData.append('file',input.files[0]);
  formData.append('kind',kind);
  toast('Enviando foto…','info');
  try{
    const res=await fetch(`/admin/save-photo-cloudinary/${encodeURIComponent(currentSku)}`,{
      method:'POST',headers:{'authorization':`Bearer ${localStorage.getItem('expedicao_token')||''}`},body:formData
    });
    if(!res.ok){const e=await res.json().catch(()=>({}));throw new Error(e.error||`HTTP ${res.status}`);}
    const data=await res.json();
    if(data.ok){toast('Foto salva ✓','ok');input.value='';await reloadProduct();}
    else throw new Error(data.error||'Falha ao salvar');
  }catch(e){toast(`Erro no upload: ${e.message}`,'err');}
  finally{if(label)label.classList.remove('photo-uploading');}
}

// ── Deletar foto ───────────────────────────────────────────────────────────
async function deletePhoto(kind,idx){
  if(!currentSku||!currentProduct)return;
  if(!confirm('Remover esta foto?'))return;
  const ov=currentProduct.override||{};
  let patch={};
  if(kind==='bin')patch.binPhoto='';
  else if(kind==='stock'){const arr=[...(ov.stockPhotos||[])];arr.splice(idx,1);patch.stockPhotos=arr;}
  else if(kind==='box'){const arr=[...(ov.boxPhotos||[])];arr.splice(idx,1);patch.boxPhotos=arr;}
  try{
    await api(`/admin/products/${encodeURIComponent(currentSku)}`,{method:'PATCH',body:JSON.stringify(patch)});
    toast('Foto removida','info');await reloadProduct();
  }catch(e){toast(`Erro: ${e.message}`,'err');}
}

// ── Reload produto ─────────────────────────────────────────────────────────
async function reloadProduct(){
  if(!currentSku)return;
  try{
    const d=await api(`/admin/products/${encodeURIComponent(currentSku)}`);
    if(!d||!d.item)return;
    const item=d.item,ov=item.override||{};
    const fix=url=>(url&&!url.startsWith('http'))?`/uploads/${url}`:url;
    item.image=fix(item.image);
    if(ov.binPhoto)ov.binPhoto=fix(ov.binPhoto);
    if(Array.isArray(ov.stockPhotos))ov.stockPhotos=ov.stockPhotos.map(fix);
    if(Array.isArray(ov.boxPhotos))ov.boxPhotos=ov.boxPhotos.map(fix);
    currentProduct=item;
    renderPanel(item);
    document.querySelectorAll('.result-item').forEach(el=>el.classList.toggle('active',el.dataset.sku===currentSku));
  }catch(e){console.error('Erro ao recarregar:',e);}
}

