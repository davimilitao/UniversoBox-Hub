<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>Admin Produtos — Expedição Pro</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/erp.css" />
  <link rel="stylesheet" href="/erp-custom.css">
  <style>
    .admin-layout {
      display: grid;
      grid-template-columns: 300px 1fr;
      height: calc(100vh - 72px);
      overflow: hidden;
    }
    @media (max-width: 860px) { .admin-layout { grid-template-columns: 1fr; height: auto; } }

    .admin-search-col { border-right: 1px solid var(--border-subtle); display: flex; flex-direction: column; overflow: hidden; }
    .left-tab-nav { display: flex; border-bottom: 1px solid var(--border-subtle); flex-shrink: 0; }
    .left-tab-btn {
      flex: 1; background: none; border: none; border-bottom: 2px solid transparent;
      padding: 10px 8px 8px; font-family: var(--font-body); font-size: 12px; font-weight: 700;
      color: var(--text-muted); cursor: pointer;
      transition: color var(--transition-fast), border-color var(--transition-fast);
    }
    .left-tab-btn:hover  { color: var(--text-primary); }
    .left-tab-btn.active { color: var(--accent-blue); border-bottom-color: var(--accent-blue); }

    .admin-search-head { padding: 10px 12px; border-bottom: 1px solid var(--border-subtle); flex-shrink: 0; }
    .search-row { display: flex; gap: 6px; align-items: center; }
    .search-hint { font-size: 11px; color: var(--text-muted); margin-top: 5px; min-height: 15px; }
    .search-filters { display: flex; gap: 5px; margin-top: 8px; flex-wrap: wrap; }
    .filter-chip {
      font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 999px; cursor: pointer;
      border: 1px solid var(--border-default); background: var(--depth-4); color: var(--text-muted); transition: all .15s;
    }
    .filter-chip:hover { border-color: var(--accent-blue); color: var(--accent-blue); }
    .filter-chip.active { background: rgba(59,130,246,.12); border-color: rgba(59,130,246,.3); color: var(--accent-blue); }
    .filter-chip.warn.active { background: rgba(245,200,66,.12); border-color: rgba(245,200,66,.3); color: var(--accent-yellow); }
    .btn-clear-search { background: none; border: none; cursor: pointer; color: var(--text-muted); font-size: 18px; padding: 0 4px; line-height: 1; display: none; }
    .btn-clear-search:hover { color: var(--text-primary); }

    .results-list { flex: 1; overflow-y: auto; }
    .results-list::-webkit-scrollbar { width: 3px; }
    .results-list::-webkit-scrollbar-thumb { background: var(--depth-5); border-radius: 2px; }
    .result-item { display: flex; align-items: center; gap: 10px; padding: 9px 12px; cursor: pointer; border-bottom: 1px solid var(--border-subtle); transition: background var(--transition-fast); }
    .result-item:hover  { background: var(--depth-4); }
    .result-item.active { background: rgba(59,130,246,.08); border-right: 3px solid var(--accent-blue); }
    .ri-img  { width: 38px; height: 38px; border-radius: var(--r-sm); object-fit: cover; background: var(--depth-5); flex-shrink: 0; }
    .ri-info { flex: 1; min-width: 0; }
    .ri-sku  { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--accent-blue); font-weight: 700; }
    .ri-name { font-size: 12px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }
    .ri-status { display: flex; gap: 4px; margin-top: 3px; align-items: center; }
    .dot-photo { width: 7px; height: 7px; border-radius: 50%; background: var(--depth-5); border: 1px solid var(--border-default); }
    .dot-photo.has { background: var(--accent-green); border-color: transparent; }

    .results-nav { padding: 8px 12px; border-top: 1px solid var(--border-subtle); display: flex; align-items: center; gap: 8px; flex-shrink: 0; }

    .admin-panel-col { overflow-y: auto; display: flex; flex-direction: column; }
    .admin-panel-col::-webkit-scrollbar { width: 4px; }
    .admin-panel-col::-webkit-scrollbar-thumb { background: var(--depth-4); border-radius: 2px; }
    .no-sel { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; color: var(--text-muted); text-align: center; padding: 40px; }
    .no-sel-icon { font-size: 44px; opacity: .15; }
    .no-sel h3 { font-size: 16px; color: var(--text-secondary); }
    .no-sel p  { font-size: 13px; max-width: 300px; line-height: 1.6; }

    /* Skeleton */
    .skeleton { background: var(--depth-4); border-radius: var(--r-sm); animation: sk 1.2s ease-in-out infinite; }
    @keyframes sk { 0%,100%{opacity:.4} 50%{opacity:.85} }
    .panel-loading { padding: 20px; display: flex; flex-direction: column; gap: 14px; }

    /* Produto */
    .prod-panel { padding: 20px; display: flex; flex-direction: column; gap: 16px; }
    .prod-hdr { background: var(--depth-3); border: 1px solid var(--border-default); border-radius: var(--r-lg); padding: 18px 20px; }
    .prod-name { font-family: var(--font-display); font-size: 17px; font-weight: 700; line-height: 1.3; }
    .prod-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px; }
    .ptag { font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: var(--r-full); background: var(--depth-5); color: var(--text-secondary); border: 1px solid var(--border-default); }
    .ptag-blue { background: rgba(59,130,246,.1); color: var(--accent-blue); border-color: rgba(59,130,246,.2); }
    .ptag-warn { background: rgba(245,200,66,.1); color: var(--accent-yellow); border-color: rgba(245,200,66,.2); }
    .ptag-marca { cursor: pointer; border-style: dashed; transition: all .15s; }
    .ptag-marca:hover { background: rgba(59,130,246,.15); border-color: var(--accent-blue); color: var(--accent-blue); }

    .bling-section { margin-top: 14px; }
    .bling-badge { display: inline-flex; align-items: center; gap: 4px; background: rgba(59,130,246,.08); border: 1px solid rgba(59,130,246,.15); border-radius: var(--r-full); padding: 3px 9px; font-size: 10px; font-weight: 700; color: var(--accent-blue); }
    .bling-badge::before { content: '⬡'; }
    .bling-readonly-label { font-size: 10px; color: var(--text-muted); }
    .bling-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px,1fr)); gap: 8px; margin-top: 10px; }
    .bling-field { background: var(--depth-4); border-radius: var(--r-sm); padding: 9px 11px; }
    .bling-label { font-size: 9px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .4px; }
    .bling-val { font-family: 'Space Mono', monospace; font-size: 14px; font-weight: 700; margin-top: 3px; }
    .bling-val.empty { color: var(--text-muted); font-size: 12px; }

    .section { background: var(--depth-3); border: 1px solid var(--border-default); border-radius: var(--r-lg); overflow: hidden; }
    .sec-hdr { padding: 12px 16px; border-bottom: 1px solid var(--border-subtle); display: flex; align-items: center; justify-content: space-between; }
    .sec-hdr-title { font-weight: 700; font-size: 13px; display: flex; align-items: center; gap: 6px; }
    .sec-body { padding: 14px 16px; }
    .system-badge { background: rgba(16,185,129,.1); border: 1px solid rgba(16,185,129,.2); border-radius: var(--r-full); padding: 2px 7px; font-size: 9px; font-weight: 700; color: var(--accent-green); }
    .field { display: flex; flex-direction: column; gap: 5px; }
    .field label { font-size: 11px; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: .4px; }
    .input-row { display: flex; gap: 8px; }
    .input-row input { flex: 1; }
    textarea { min-height: 80px; resize: vertical; }

    /* Btn loader */
    .btn-loading { position: relative; pointer-events: none; opacity: .75; }
    .btn-loading::after {
      content: ''; position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
      width: 10px; height: 10px; border: 2px solid currentColor; border-top-color: transparent;
      border-radius: 50%; animation: spin .6s linear infinite;
    }
    @keyframes spin { to { transform: translateY(-50%) rotate(360deg); } }

    /* Fotos */
    .photo-section { display: flex; flex-direction: column; gap: 16px; }
    .photo-group-label { font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .4px; margin-bottom: 8px; }
    .photo-strip { display: flex; flex-wrap: wrap; gap: 8px; }
    .photo-card { position: relative; width: 100px; height: 100px; border-radius: var(--r-md); overflow: hidden; border: 1px solid var(--border-default); }
    .photo-card img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .photo-overlay { position: absolute; inset: 0; background: rgba(0,0,0,.5); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity .15s; }
    .photo-card:hover .photo-overlay { opacity: 1; }
    .photo-del { background: none; border: none; color: #fff; font-size: 20px; cursor: pointer; }
    .photo-add {
      width: 100px; height: 100px; border-radius: var(--r-md);
      border: 2px dashed var(--border-default); display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 5px; cursor: pointer; background: var(--depth-4); transition: .15s;
    }
    .photo-add:hover { border-color: var(--accent-blue); background: rgba(59,130,246,.05); }
    .photo-add input[type=file] { display: none; }
    .photo-add-icon  { font-size: 20px; }
    .photo-add-label { font-size: 10px; font-weight: 700; color: var(--text-muted); }
    .photo-uploading { opacity: .5; pointer-events: none; }

    .bin-photo-wrap { position: relative; display: inline-block; }
    .bin-photo-wrap img { width: 120px; height: 120px; object-fit: cover; border-radius: var(--r-md); border: 1px solid var(--border-default); display: block; }
    .bin-photo-date { font-size: 10px; color: var(--text-muted); margin-top: 4px; }

    /* Embalagens */
    .emb-sugg { display: flex; flex-direction: column; gap: 6px; }
    .emb-sugg-item { display: flex; align-items: center; gap: 10px; padding: 10px 12px; background: var(--depth-4); border-radius: var(--r-md); border: 1px solid var(--border-subtle); }
    .emb-sugg-name { font-size: 13px; font-weight: 700; }
    .emb-sugg-stock { font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 700; }
    .emb-sugg-stock.ok   { color: var(--accent-green); }
    .emb-sugg-stock.warn { color: var(--accent-yellow); }
    .emb-sugg-stock.low  { color: var(--accent-red); }
    .emb-empty { font-size: 13px; color: var(--text-muted); line-height: 1.6; }

    /* Modal */
    .modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.55); z-index: 999; display: none; align-items: center; justify-content: center; }
    .modal-backdrop.open { display: flex; }
    .modal-box { background: var(--depth-2); border: 1px solid var(--border-default); border-radius: var(--r-lg); padding: 20px; width: 340px; max-width: 90vw; }
    .modal-title { font-size: 14px; font-weight: 700; margin-bottom: 14px; }
    .modal-footer { display: flex; gap: 8px; justify-content: flex-end; margin-top: 16px; }

    /* Marcas */
    .marca-card { display: flex; flex-direction: column; gap: 6px; padding: 9px 10px; background: var(--depth-3); border: 1px solid var(--border-default); border-radius: var(--r-md); transition: background var(--transition-fast); }
    .marca-card:hover { background: var(--depth-4); }
    .marca-card-top { display: flex; align-items: center; gap: 8px; }
    .marca-thumb { width: 36px; height: 36px; border-radius: var(--r-sm); object-fit: cover; background: var(--depth-5); flex-shrink: 0; border: 1px solid var(--border-subtle); }
    .marca-info { flex: 1; min-width: 0; }
    .marca-name { font-size: 12px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .marca-sku  { font-family: 'Space Mono', monospace; font-size: 9px; color: var(--accent-blue); font-weight: 700; margin-top: 1px; }
    .marca-controls { display: flex; gap: 5px; align-items: center; }
    .marca-sel { flex: 1; min-width: 0; background: var(--depth-4); border: 1px solid var(--border-default); border-radius: var(--r-md); padding: 5px 7px; color: var(--text-primary); font-family: var(--font-body); font-size: 11px; outline: none; }
    .marca-sel:focus { border-color: var(--accent-blue); }
    .marca-nova-input { flex: 1; min-width: 0; background: var(--depth-4); border: 1px solid var(--border-default); border-radius: var(--r-md); padding: 5px 7px; color: var(--text-primary); font-family: var(--font-body); font-size: 11px; outline: none; display: none; }
    .marca-nova-input:focus { border-color: var(--accent-green); }
  </style>
  <script src="/auth-guard.js"></script>
</head>
<body>

<div class="erp-layout">
  <div id="sidebar-placeholder"></div>
  <main class="erp-main" style="overflow:hidden;display:flex;flex-direction:column;">

    <div class="page-header" style="flex-shrink:0;padding-bottom:12px;">
      <div>
        <h1 class="page-title">🖼️ Admin Produtos</h1>
        <p class="page-subtitle">Fotos, localização e notas operacionais</p>
      </div>
    </div>

    <div class="admin-layout">

      <!-- COLUNA ESQUERDA -->
      <div class="admin-search-col">
        <div class="left-tab-nav">
          <button class="left-tab-btn active" data-ltab="produtos" onclick="switchLeftTab('produtos')">Produtos</button>
          <button class="left-tab-btn" data-ltab="marcas" onclick="switchLeftTab('marcas')">
            Marcas
            <span id="badgeSemMarca" style="display:none;background:var(--accent-yellow);color:#000;border-radius:999px;font-size:9px;font-weight:700;padding:1px 5px;margin-left:4px;"></span>
          </button>
        </div>

        <!-- Tab Produtos -->
        <div id="ltab-produtos" style="display:flex;flex-direction:column;flex:1;overflow:hidden;">
          <div class="admin-search-head">
            <div class="search-row">
              <input type="text" id="searchInput" placeholder="SKU, EAN ou nome…"
                style="flex:1;background:var(--depth-4);border:1px solid var(--border-default);border-radius:var(--r-md);padding:8px 10px;color:var(--text-primary);font-family:var(--font-body);font-size:13px;outline:none;"
                autocomplete="off" />
              <button class="btn-clear-search" id="btnClearSearch" onclick="clearSearch()">×</button>
            </div>
            <div class="search-hint" id="searchHint">Digite ao menos 3 letras</div>
            <div class="search-filters">
              <span class="filter-chip" id="chip-sem-foto" onclick="toggleFilter('sem-foto')">Sem foto</span>
              <span class="filter-chip warn" id="chip-sem-marca" onclick="toggleFilter('sem-marca')">Sem marca</span>
            </div>
          </div>
          <div class="results-list" id="resultsList">
            <div style="padding:20px;text-align:center;font-size:13px;color:var(--text-muted);">Busque um produto acima</div>
          </div>
          <div class="results-nav" id="resultsNav" style="display:none;">
            <span id="navInfo" style="font-size:11px;color:var(--text-muted);font-family:'Space Mono',monospace;flex:1;"></span>
            <button class="btn btn-sm" id="btnNavPrev" onclick="navProduto(-1)" style="font-size:12px;">←</button>
            <button class="btn btn-sm" id="btnNavNext" onclick="navProduto(1)"  style="font-size:12px;">→</button>
          </div>
        </div>

        <!-- Tab Marcas -->
        <div id="ltab-marcas" style="display:none;flex-direction:column;flex:1;overflow:hidden;">
          <div style="padding:10px 12px;border-bottom:1px solid var(--border-subtle);flex-shrink:0;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
              <span id="marcasCounter" style="display:none;font-family:'Space Mono',monospace;font-size:10px;font-weight:700;padding:2px 8px;border-radius:999px;background:rgba(245,200,66,.12);color:var(--accent-yellow);border:1px solid rgba(245,200,66,.2);"></span>
              <button class="btn btn-sm" style="font-size:11px;margin-left:auto;" onclick="marcasAdmin.reload()">↺</button>
            </div>
            <input id="marcasSearch" type="search" placeholder="Filtrar nome ou SKU…" autocomplete="off"
              style="width:100%;background:var(--depth-4);border:1px solid var(--border-default);border-radius:var(--r-md);padding:7px 10px;color:var(--text-primary);font-family:var(--font-body);font-size:12px;outline:none;box-sizing:border-box;"
              oninput="marcasAdmin.filtrar(this.value)" />
          </div>
          <div id="marcasListWrap" style="flex:1;overflow-y:auto;padding:8px 10px;display:flex;flex-direction:column;gap:5px;">
            <div id="marcasLoading" style="padding:30px 10px;text-align:center;font-size:13px;color:var(--text-muted);">Carregando…</div>
            <div id="marcasEmpty" style="display:none;padding:30px 10px;text-align:center;font-size:13px;color:var(--text-muted);">✓ Todos têm marca válida.</div>
            <div id="marcasList"></div>
          </div>
          <div id="marcasPag" style="display:none;justify-content:center;align-items:center;gap:6px;padding:8px 10px;border-top:1px solid var(--border-subtle);flex-shrink:0;">
            <button class="btn btn-sm" id="marcasPrev" style="font-size:11px;">←</button>
            <span id="marcasPagInfo" style="font-size:11px;color:var(--text-muted);font-family:'Space Mono',monospace;"></span>
            <button class="btn btn-sm" id="marcasNext" style="font-size:11px;">→</button>
          </div>
        </div>
      </div>

      <!-- PAINEL DIREITO -->
      <div class="admin-panel-col">
        <div class="no-sel" id="noSel">
          <div class="no-sel-icon">🖼️</div>
          <h3>Selecione um produto</h3>
          <p>Busque pelo SKU, EAN ou nome na coluna ao lado.</p>
        </div>
        <div id="prodPanel" style="display:none;"></div>
      </div>
    </div>
  </main>
</div>

<!-- Modal marca -->
<div class="modal-backdrop" id="modalMarca">
  <div class="modal-box">
    <div class="modal-title">Editar marca</div>
    <div style="display:flex;flex-direction:column;gap:10px;">
      <select id="modalMarcaSel" style="width:100%;background:var(--depth-4);border:1px solid var(--border-default);border-radius:var(--r-md);padding:8px 10px;color:var(--text-primary);font-family:var(--font-body);font-size:13px;outline:none;">
        <option value="">— Selecionar —</option>
        <option value="__nova__">+ Nova marca…</option>
      </select>
      <input id="modalMarcaNova" type="text" placeholder="Nome da nova marca" autocomplete="off"
        style="display:none;background:var(--depth-4);border:1px solid var(--border-default);border-radius:var(--r-md);padding:8px 10px;color:var(--text-primary);font-family:var(--font-body);font-size:13px;outline:none;width:100%;box-sizing:border-box;" />
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="fecharModalMarca()">Cancelar</button>
      <button class="btn btn-primary btn-sm" id="btnSalvarMarcaModal" onclick="salvarMarcaModal()">Salvar</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>
<script src="/menu.js"></script>
<script>
'use strict';

const TERMINAL_KEY = 'expedicao_pro_terminal_id';
function tid(){let id=localStorage.getItem(TERMINAL_KEY);if(!id){id=crypto.randomUUID();localStorage.setItem(TERMINAL_KEY,id);}return id;}

async function api(path,opts={}){
  const token=localStorage.getItem('expedicao_token')||'';
  const res=await fetch(path,{...opts,headers:{'content-type':'application/json','x-terminal-id':tid(),'authorization':`Bearer ${token}`,...(opts.headers||{})}});
  const d=await res.json().catch(()=>({}));
  if(res.status===401){window.location.href='/login';return null;}
  if(!res.ok)throw new Error(d.error||`HTTP ${res.status}`);
  return d;
}

function esc(s){return(s??'').toString().replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'})[m]);}

let _tt=null;
function toast(msg,type='info'){
  const el=document.getElementById('toast');
  el.textContent=msg;el.className=`toast show ${type}`;
  clearTimeout(_tt);_tt=setTimeout(()=>el.classList.remove('show'),2800);
}

let currentSku=null,currentProduct=null,searchTimer=null,embalagens=[];
let _searchResults=[],_currentIdx=-1,_activeFilter=null;
let _marcasListGlobal=[];

async function loadEmbalagens(){try{const d=await api('/embalagens/list');if(d)embalagens=d.items||[];}catch{}}

// ── Busca ──────────────────────────────────────────────────────────────────
const searchInput=document.getElementById('searchInput');
searchInput.addEventListener('input',()=>{
  clearTimeout(searchTimer);
  const q=searchInput.value.trim();
  document.getElementById('btnClearSearch').style.display=q?'block':'none';
  if(q.length<2){
    if(_activeFilter){doFilter(_activeFilter);return;}
    document.getElementById('searchHint').textContent='Digite ao menos 3 letras';
    return;
  }
  document.getElementById('searchHint').textContent='Buscando…';
  searchTimer=setTimeout(()=>doSearch(q),250);
});

function clearSearch(){
  searchInput.value='';
  document.getElementById('btnClearSearch').style.display='none';
  document.getElementById('searchHint').textContent='Digite ao menos 3 letras';
  document.getElementById('resultsList').innerHTML='<div style="padding:20px;text-align:center;font-size:13px;color:var(--text-muted);">Busque um produto acima</div>';
  document.getElementById('resultsNav').style.display='none';
  _searchResults=[];_currentIdx=-1;
  if(_activeFilter){
    document.getElementById('chip-'+_activeFilter).classList.remove('active');
    _activeFilter=null;
  }
}

async function doSearch(q){
  try{
    const d=await api(`/admin/products/search?q=${encodeURIComponent(q)}`);
    if(!d)return;
    _searchResults=d.items||[];
    _currentIdx=_searchResults.findIndex(p=>p.sku===currentSku);
    renderResults(_searchResults);
  }catch(e){document.getElementById('searchHint').textContent=`Erro: ${e.message}`;}
}

function toggleFilter(filter){
  if(_activeFilter===filter){
    _activeFilter=null;
    document.getElementById('chip-'+filter).classList.remove('active');
    clearSearch();
    return;
  }
  _activeFilter=filter;
  document.querySelectorAll('.filter-chip').forEach(c=>c.classList.remove('active'));
  document.getElementById('chip-'+filter).classList.add('active');
  searchInput.value='';
  document.getElementById('btnClearSearch').style.display='none';
  doFilter(filter);
}

async function doFilter(filter){
  document.getElementById('searchHint').textContent='Carregando…';
  document.getElementById('resultsList').innerHTML='<div style="padding:20px;text-align:center;font-size:13px;color:var(--text-muted);">Carregando…</div>';
  try{
    let items=[];
    if(filter==='sem-foto'){
      const d=await api('/products/all?limit=500');
      if(d)items=(d.items||[]).filter(p=>!(p.override?.stockPhotos?.length>0));
    }else if(filter==='sem-marca'){
      const d=await api('/products/sem-marca?limit=500');
      if(d)items=(d.items||[]).map(p=>({...p,override:{}}));
    }
    _searchResults=items;
    _currentIdx=items.findIndex(p=>p.sku===currentSku);
    renderResults(items,`${items.length} produto(s) ${filter==='sem-foto'?'sem foto':'sem marca'}`);
  }catch(e){document.getElementById('searchHint').textContent=`Erro: ${e.message}`;}
}

function renderResults(items,hintOverride){
  const list=document.getElementById('resultsList');
  const hint=document.getElementById('searchHint');
  hint.textContent=hintOverride||`${items.length} resultado(s)`;
  list.innerHTML='';
  if(!items.length){
    list.innerHTML='<div style="padding:16px;text-align:center;font-size:13px;color:var(--text-muted);">Nenhum resultado</div>';
    document.getElementById('resultsNav').style.display='none';
    return;
  }
  for(const p of items){
    const hasStock=p.override?.stockPhotos?.length>0;
    const hasBin=!!p.override?.binPhoto;
    const imgSrc=p.displayImage||'/assets/placeholder.png';
    const div=document.createElement('div');
    div.className=`result-item${p.sku===currentSku?' active':''}`;
    div.dataset.sku=p.sku;
    div.innerHTML=`
      <img class="ri-img" src="${esc(imgSrc)}" onerror="this.src='/assets/placeholder.png'" alt="">
      <div class="ri-info">
        <div class="ri-sku">${esc(p.sku||'')}</div>
        <div class="ri-name">${esc(p.name||'')}</div>
        <div class="ri-status">
          <span class="dot-photo ${hasStock?'has':''}" title="Foto produto"></span>
          <span class="dot-photo ${hasBin?'has':''}" title="Foto prateleira"></span>
        </div>
      </div>`;
    div.addEventListener('click',()=>selectProduct(p.sku));
    list.appendChild(div);
  }
  if(items.length>1){
    document.getElementById('resultsNav').style.display='flex';
    _updateNavInfo();
  }else{
    document.getElementById('resultsNav').style.display='none';
  }
}

function _updateNavInfo(){
  if(!_searchResults.length){document.getElementById('resultsNav').style.display='none';return;}
  document.getElementById('navInfo').textContent=_currentIdx>=0?`${_currentIdx+1} / ${_searchResults.length}`:`— / ${_searchResults.length}`;
  document.getElementById('btnNavPrev').disabled=_currentIdx<=0;
  document.getElementById('btnNavNext').disabled=_currentIdx>=_searchResults.length-1||_currentIdx<0;
}

function navProduto(dir){
  const next=_currentIdx+dir;
  if(next<0||next>=_searchResults.length)return;
  selectProduct(_searchResults[next].sku);
}

// ── Selecionar produto ─────────────────────────────────────────────────────
async function selectProduct(sku){
  currentSku=sku;
  _currentIdx=_searchResults.findIndex(p=>p.sku===sku);
  _updateNavInfo();
  document.querySelectorAll('.result-item').forEach(el=>el.classList.toggle('active',el.dataset.sku===sku));
  document.getElementById('noSel').style.display='none';
  const panel=document.getElementById('prodPanel');
  panel.style.display='block';
  panel.innerHTML=`<div class="panel-loading">
    <div class="skeleton" style="height:130px;border-radius:var(--r-lg);"></div>
    <div class="skeleton" style="height:90px;border-radius:var(--r-lg);"></div>
    <div class="skeleton" style="height:200px;border-radius:var(--r-lg);"></div>
  </div>`;
  try{
    const d=await api(`/admin/products/${encodeURIComponent(sku)}`);
