            <div id="full-est-body"><div class="loading-bar"><span class="spin">⟳</span></div></div>
          </div>
          <div class="full-panel" id="full-vendas">
            <div class="vf-row">
              <span style="font-size:11px;font-weight:700;color:var(--text-muted);">Período:</span>
              <button class="vf-btn active" onclick="loadVendas(1,this)">Hoje</button>
              <button class="vf-btn" onclick="loadVendas(7,this)">7 dias</button>
              <button class="vf-btn" onclick="loadVendas(30,this)">30 dias</button>
              <span id="vend-total" style="margin-left:auto;font-size:11px;color:var(--text-muted);"></span>
            </div>
            <div id="full-vend-body"><div class="loading-bar"><span class="spin">⟳</span></div></div>
          </div>
          <div class="full-panel" id="full-insights">
            <div class="ig-grid" id="full-ins-body"><div class="loading-bar"><span class="spin">⟳</span></div></div>
          </div>
        </div>
