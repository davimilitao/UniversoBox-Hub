      <!-- SCANNER -->
      <div class="ml-panel" id="panel-scanner">
        <div class="scan-layout">
          <div class="scan-card">
            <div class="scan-hdr">
              <span style="font-size:22px;">📷</span>
              <div>
                <div style="font-size:14px;font-weight:700;">Baixa por Rastreio</div>
                <div style="font-size:11px;color:var(--text-muted);">Bipe o código da etiqueta de transporte</div>
              </div>
            </div>
            <div class="scan-body">
              <div class="scan-wrap">
                <input type="text" class="scan-inp" id="scan-inp" placeholder="Bipe ou digite o rastreio…" autocomplete="off" spellcheck="false" onkeydown="if(event.key==='Enter')processBaixa()" />
                <button class="btn btn-grn" onclick="processBaixa()" style="font-size:18px;padding:0 16px;">✓</button>
              </div>
              <div class="scan-res" id="scan-res"></div>
