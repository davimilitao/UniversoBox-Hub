<div class="toast-cont" id="toasts"></div>
<script src="/menu.js"></script>
<script>
const S={orders:[],logF:'all',stF:'todos',selId:null,baixas:[],reclam:[],estoque:[],vendas:[],venDias:1};

document.addEventListener('DOMContentLoaded',()=>{
  refreshAll();
  setInterval(loadShipments,60000);
  const d=document.getElementById('baixas-date');
  if(d)d.textContent=new Date().toLocaleDateString('pt-BR',{weekday:'short',day:'2-digit',month:'2-digit'});
});

async function refreshAll(){
  document.getElementById('last-up').textContent='';
  await Promise.allSettled([loadOrders(),loadShipments(),loadReclamacoes()]);
  document.getElementById('last-up').textContent='Atualizado '+new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
}

function showTab(n){
  document.querySelectorAll('.ml-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.ml-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('panel-'+n).classList.add('active');
  document.getElementById('tab-'+(n==='reclamacoes'?'reclam':n)).classList.add('active');
  if(n==='scanner')setTimeout(()=>document.getElementById('scan-inp')?.focus(),80);
  if(n==='full'&&!S.estoque.length)loadFullData();
}

function showFull(n,el){
  document.querySelectorAll('.full-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.fstab').forEach(t=>t.classList.remove('active'));
  document.getElementById('full-'+n).classList.add('active');
  el.classList.add('active');
}

// ── TOPBAR ──────────────────────────────────
async function loadShipments(){
  try{
    const r=await fetch('/api/ml/shipments/today');
    if(!r.ok){renderTopOff();return;}
    renderTop(await r.json());
  }catch{renderTopOff();}
}

function renderTopOff(){
  document.getElementById('topbar').innerHTML=`<span style="font-size:12px;color:var(--text-muted);">⚠️ Sem dados de envio <button class="btn btn-def btn-sm" onclick="loadShipments()" style="margin-left:8px;">Tentar</button></span>`;
  const d=document.getElementById('conn-dot');if(d){d.style.background='var(--accent-red)';d.style.boxShadow='';}
}

function renderTop(d){
  const dot=document.getElementById('conn-dot');
  if(dot){dot.style.background='var(--accent-green)';dot.style.boxShadow='0 0 6px rgba(16,185,129,.5)';}
  const sh=d.shipments||[];
  const ag=sh.filter(s=>s.logistica==='agency').length;
  const fx=sh.filter(s=>s.logistica==='flex').length;
  const fu=sh.filter(s=>s.logistica==='fulfillment').length;
  const co=sh.filter(s=>s.logistica==='pickup').length;
  let corte='';
  if(d.cutoffTime){
    const ct=new Date(d.cutoffTime);
    const hm=ct.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
    const df=ct-Date.now();const rm=Math.max(0,Math.floor(df/60000));
    const cd=df>0?`${Math.floor(rm/60)?Math.floor(rm/60)+'h ':''}${rm%60}min restantes`:'⚠️ Encerrado';
    corte=`<div class="corte-box"><div class="corte-time">${hm}</div><div class="corte-lbl">Corte Agência</div><div class="corte-cd">${cd}</div></div>`;
  }
  let auth='';
  if(d.authCode)auth=`<div class="auth-bar" onclick="navigator.clipboard.writeText('${d.authCode}').then(()=>toast('Copiado!','ok'))" title="Copiar"><div><span class="auth-lbl">Código Flex hoje</span><span class="auth-code">${d.authCode}</span></div><span style="opacity:.4;">📋</span></div>`;
  document.getElementById('topbar').innerHTML=`${corte}
    ${ag?`<div class="lchip ag"><span class="lchip-val">${ag}</span><span class="lchip-lbl">Agência</span></div>`:''}
    ${fx?`<div class="lchip fx"><span class="lchip-val">${fx}</span><span class="lchip-lbl">Flex</span></div>`:''}
    ${fu?`<div class="lchip fu"><span class="lchip-val">${fu}</span><span class="lchip-lbl">Full CD</span></div>`:''}
    ${co?`<div class="lchip co"><span class="lchip-val">${co}</span><span class="lchip-lbl">Coleta</span></div>`:''}
    ${auth}
    <div style="margin-left:auto;"><a href="https://www.mercadolivre.com.br/vendas" target="_blank" class="btn btn-def btn-sm">↗ Abrir ML</a></div>`;
}

// ── PEDIDOS ──────────────────────────────────
async function loadOrders(){
  document.getElementById('ped-list').innerHTML='<div class="loading-bar"><span class="spin">⟳</span> Buscando pedidos…</div>';
  try{
    const r=await fetch('/api/ml/orders/today');
    const d=await r.json();
    if(!r.ok)throw new Error(d.error||`HTTP ${r.status}`);
    // Separa Full (tem aba própria) de Agência/Flex
    S.orders=(d.orders||[]).filter(o=>o.logistica!=='fulfillment');
    const full=(d.orders||[]).filter(o=>o.logistica==='fulfillment');
    document.getElementById('badge-full').textContent=full.length||'—';
    document.getElementById('badge-pedidos').textContent=S.orders.length||'—';
    updateCnt();renderList();
  }catch(e){
    document.getElementById('ped-list').innerHTML=`<div class="loading-bar" style="color:var(--accent-red);">⚠️ ${e.message}</div>`;
  }
}

function updateCnt(){
  const o=S.orders;
  document.getElementById('cnt-todos').textContent=o.length;
  document.getElementById('cnt-imprimir').textContent=o.filter(x=>x._localStatus==='imprimir').length;
  document.getElementById('cnt-expedir').textContent=o.filter(x=>x._localStatus==='expedir').length;
  document.getElementById('cnt-enviado').textContent=o.filter(x=>x._localStatus==='enviado').length;
}

function filterLog(l,el){
  S.logF=l;
  document.querySelectorAll('.ltab').forEach(t=>t.className='ltab');
  el.classList.add(l==='all'?'a-all':l==='agency'?'a-ag':'a-fx');
  renderList();
}

function filterSt(s,el){
  S.stF=s;
  document.querySelectorAll('.stab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');renderList();
}

function renderList(){
  const q=(document.getElementById('ped-search')?.value||'').toLowerCase();
  let list=S.orders;
  if(S.logF!=='all')list=list.filter(o=>o.logistica===S.logF);
  if(S.stF!=='todos')list=list.filter(o=>o._localStatus===S.stF);
  if(q)list=list.filter(o=>(o.buyer?.nickname||'').toLowerCase().includes(q)||(o.order_items||[]).some(i=>(i.item?.title||'').toLowerCase().includes(q))||String(o.id).includes(q));

  if(!list.length){
    document.getElementById('ped-list').innerHTML='<div class="empty-state" style="padding:24px 12px;"><div class="empty-icon">📭</div><div class="empty-msg">Nenhum pedido</div></div>';
    return;
  }
  const LB={agency:'🟡 Agência',flex:'🔵 Flex',pickup:'🟣 Coleta'};
  const LC={agency:'bl-ag',flex:'bl-fx',pickup:'bl-co'};
  const SM={imprimir:'Imprimir',expedir:'Expedir',enviado:'Enviado',cancelado:'Cancelado'};
  const SC={imprimir:'bs-imp',expedir:'bs-exp',enviado:'bs-env',cancelado:'bs-can'};
  document.getElementById('ped-list').innerHTML=list.map(o=>{
    const nick=o.buyer?.nickname||'—';
    const val=o.total_amount?`R$ ${Number(o.total_amount).toFixed(2)}`:'';
    const hora=o._createdTime||'';
    const prod=(o.order_items||[]).map(i=>i.item?.title||'').filter(Boolean).join(', ');
    return`<button class="ocard ${S.selId===String(o.id)?'sel':''}" data-log="${o.logistica}" data-st="${o._localStatus}" onclick="selOrder('${o.id}')">
      <div class="ocard-top">
        <span class="ocard-nick">${nick}</span>
        <div style="display:flex;gap:3px;">
          ${LB[o.logistica]?`<span class="bl ${LC[o.logistica]}">${LB[o.logistica]}</span>`:''}
          <span class="bs ${SC[o._localStatus]||''}">${SM[o._localStatus]||'—'}</span>
        </div>
      </div>
      <div class="ocard-meta">${val?`<span>${val}</span>`:''} ${hora?`<span>⏱ ${hora}</span>`:''}</div>
      ${prod?`<div class="ocard-prod">${prod}</div>`:''}
    </button>`;
  }).join('');
}

function selOrder(id){
  S.selId=String(id);renderList();
  const o=S.orders.find(x=>String(x.id)===String(id));
  if(o)renderDetail(o);
}

function renderDetail(o){
  const el=document.getElementById('ped-detail');
  const nick=o.buyer?.nickname||'—';
  const nome=o.buyer?.full_name||'';
  const total=o.total_amount?`R$ ${Number(o.total_amount).toFixed(2)}`:'';
  const track=o.shipping?.tracking_number||o.shipment?.tracking_number||'';
  const st=o._localStatus||'imprimir';
  const LM={agency:'Agência ML',flex:'Flex',pickup:'Coleta'};
  const SM={imprimir:'Imprimir DANFE',expedir:'Pronto p/ Expedir',enviado:'Enviado',cancelado:'Cancelado'};
  const SC={imprimir:'bs-imp',expedir:'bs-exp',enviado:'bs-env',cancelado:'bs-can'};
  const LC={agency:'bl-ag',flex:'bl-fx',pickup:'bl-co'};
  const logBdg=LM[o.logistica]?`<span class="bl ${LC[o.logistica]}">${LM[o.logistica]}</span>`:'';
  const items=(o.order_items||[]).map(it=>{
    const i=it.item||{};
    return`<div class="ml-irow">
      <img class="ml-ith" src="${i.thumbnail||'/assets/placeholder.png'}" onerror="this.src='/assets/placeholder.png'" />
      <div><div class="ml-itit">${i.title||'Produto'}</div>${i.seller_sku?`<div class="ml-isku">${i.seller_sku}</div>`:''}</div>
      <div><div class="ml-iqty">${it.quantity||1}x</div>${it.unit_price?`<div class="ml-iprc">R$ ${Number(it.unit_price).toFixed(2)}</div>`:''}</div>
    </div>`;
  }).join('');
  const btnImp=`<button class="btn btn-yel" onclick="imprimirDANFE('${o.id}')">🖨️ DANFE</button>`;
  const btnExp=st!=='enviado'?`<button class="btn btn-pri" onclick="marcarSt('${o.id}','expedir')">📤 Expedir</button>`:'';
  const btnEnv=st==='expedir'?`<button class="btn btn-grn" onclick="marcarSt('${o.id}','enviado')">✅ Enviado</button>`:'';
  const btnEtq=o.logistica==='flex'?`<button class="btn btn-def" onclick="getEtiqueta('${o.id}')">🏷️ Etiqueta</button>`:'';
  el.innerHTML=`
    <div class="pd-hdr">
      <div>
        <div class="pd-nick">${nick}${nome?` <span style="font-size:12px;font-weight:400;color:var(--text-muted);">(${nome})</span>`:''}</div>
        <div class="pd-meta2">
          <span class="bs ${SC[st]}">${SM[st]||st}</span>${logBdg}
          ${total?`<span style="font-family:'Space Mono',monospace;font-size:12px;color:var(--accent-green);">${total}</span>`:''}
          ${track?`<span style="font-size:10px;color:var(--text-muted);">📦 ${track}</span>`:''}
        </div>
      </div>
      <div class="pd-acts">${btnImp}${btnExp}${btnEnv}${btnEtq}</div>
    </div>
    <div class="pd-items">${items||'<div class="empty-state"><div class="empty-msg">Sem itens</div></div>'}</div>
    <div class="pd-foot">
      <span style="font-size:11px;color:var(--text-muted);">#${o.id}</span>
      <a href="https://www.mercadolivre.com.br/vendas/pedidos/${o.id}" target="_blank" class="btn btn-def btn-sm">↗ Ver no ML</a>
    </div>`;
}

async function marcarSt(id,st){
  try{
    await fetch(`/api/ml/orders/${id}/status`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:st})});
    const o=S.orders.find(x=>String(x.id)===String(id));
    if(o){o._localStatus=st;updateCnt();renderList();renderDetail(o);}
    toast(st==='expedir'?'Marcado para expedir':'✅ Enviado!','ok');
  }catch(e){toast(e.message,'er');}
}

async function imprimirDANFE(id){
  toast('Buscando DANFE no Bling…','in');
  try{
    const r=await fetch(`/api/ml/orders/${id}/danfe`);
    const d=await r.json();
    if(d.danfeUrl)window.open(d.danfeUrl,'_blank');
    else if(d.blingUrl){toast('DANFE não encontrada — abrindo Bling','in');window.open(d.blingUrl,'_blank');}
    else toast('DANFE não encontrada','er');
  }catch(e){toast(e.message,'er');}
}

async function getEtiqueta(id){
  toast('Buscando etiqueta Flex…','in');
  try{
    const r=await fetch(`/api/ml/orders/${id}/label`);
    const d=await r.json();
    if(d.pdfUrl)window.open(d.pdfUrl,'_blank');
    else toast('Etiqueta não disponível ainda','er');
  }catch(e){toast(e.message,'er');}
}

// ── GESTÃO FULL ──────────────────────────────
async function loadFullData(){loadEstoque();loadVendas(S.venDias,null);}

async function loadEstoque(){
  document.getElementById('full-est-body').innerHTML='<div class="loading-bar"><span class="spin">⟳</span></div>';
  document.getElementById('full-kpis').innerHTML='<div class="loading-bar"><span class="spin">⟳</span></div>';
  try{
    const r=await fetch('/api/ml/full/estoque');
    const d=await r.json();
    if(!r.ok)throw new Error(d.error||'Erro');
    S.estoque=d.items||[];
    renderKpis(S.estoque);renderEstoque(S.estoque);
    renderInsights(S.estoque,S.vendas);
  }catch(e){
    document.getElementById('full-est-body').innerHTML=`<div class="loading-bar" style="color:var(--accent-red);">⚠️ ${e.message}</div>`;
    document.getElementById('full-kpis').innerHTML='';
  }
}

function renderKpis(items){
  const tot=items.length,crit=items.filter(i=>i.available_quantity<=3).length,bx=items.filter(i=>i.available_quantity>3&&i.available_quantity<=10).length,ok=items.filter(i=>i.available_quantity>10).length,un=items.reduce((a,i)=>a+(i.available_quantity||0),0);
  document.getElementById('full-kpis').innerHTML=`
    <div class="kpi-card"><div class="kpi-val kv-b">${tot}</div><div class="kpi-lbl">SKUs no CD</div></div>
    <div class="kpi-card"><div class="kpi-val kv-g">${un}</div><div class="kpi-lbl">Unidades Totais</div></div>
    <div class="kpi-card"><div class="kpi-val kv-y">${bx}</div><div class="kpi-lbl">Estoque Baixo</div><div class="kpi-sub">≤10 unidades</div></div>
    <div class="kpi-card"><div class="kpi-val kv-r">${crit}</div><div class="kpi-lbl">Crítico</div><div class="kpi-sub">≤3 unidades</div></div>
    <div class="kpi-card"><div class="kpi-val kv-g">${ok}</div><div class="kpi-lbl">Estoque OK</div><div class="kpi-sub">&gt;10 unidades</div></div>`;
}

function renderEstoque(items){
  if(!items.length){document.getElementById('full-est-body').innerHTML='<div class="empty-state"><div class="empty-icon">📦</div><div class="empty-msg">Sem produtos no Full</div></div>';return;}
  const sorted=[...items].sort((a,b)=>(a.available_quantity||0)-(b.available_quantity||0));
  const mx=Math.max(...sorted.map(i=>i.available_quantity||0),1);
  document.getElementById('full-est-body').innerHTML=`<table class="ftable"><thead><tr><th>Produto</th><th>SKU</th><th>Disponível</th><th>Nível</th><th>Status</th></tr></thead><tbody>${
    sorted.map(item=>{
      const q=item.available_quantity||0;
      const pct=Math.round((q/mx)*100);
      const cls=q<=3?'sb-cr':q<=10?'sb-lo':'sb-ok';
      const at=q<=3?`<span class="atag at-cr">⚠️ Crítico</span>`:q<=10?`<span class="atag at-lo">⚡ Baixo</span>`:`<span class="atag at-ok">✓ OK</span>`;
      return`<tr>
        <td style="display:flex;align-items:center;gap:10px;">
          <img src="${item.thumbnail||'/assets/placeholder.png'}" style="width:34px;height:34px;border-radius:4px;object-fit:cover;flex-shrink:0;" onerror="this.src='/assets/placeholder.png'" />
          <span style="font-size:12px;font-weight:600;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${item.title||''}">${item.title||'—'}</span>
        </td>
        <td><span style="font-family:'Space Mono',monospace;font-size:10px;color:var(--accent-blue);">${item.seller_sku||'—'}</span></td>
        <td><span style="font-family:'Space Mono',monospace;font-size:14px;font-weight:700;color:${q<=3?'var(--accent-red)':q<=10?'var(--accent-yellow)':'var(--accent-green)'};">${q}</span></td>
        <td><div class="sbar-w"><div class="sbar ${cls}" style="width:${pct}%"></div></div></td>
        <td>${at}</td>
      </tr>`;
    }).join('')
  }</tbody></table>`;
}

async function loadVendas(dias,el){
  S.venDias=dias;
  if(el){document.querySelectorAll('.vf-btn').forEach(b=>b.classList.remove('active'));el.classList.add('active');}
  document.getElementById('full-vend-body').innerHTML='<div class="loading-bar"><span class="spin">⟳</span></div>';
  try{
    const r=await fetch(`/api/ml/full/vendas?dias=${dias}`);
    const d=await r.json();
    if(!r.ok)throw new Error(d.error||'Erro');
    S.vendas=d.vendas||[];
    const tot=S.vendas.reduce((a,v)=>a+(v.quantidade||0),0);
    const val=S.vendas.reduce((a,v)=>a+(v.receita||0),0);
    document.getElementById('vend-total').textContent=`${tot} un · R$ ${val.toFixed(2)}`;
    if(!S.vendas.length){document.getElementById('full-vend-body').innerHTML='<div class="empty-state"><div class="empty-icon">📊</div><div class="empty-msg">Sem vendas no período</div></div>';return;}
    document.getElementById('full-vend-body').innerHTML=S.vendas.map(v=>`
      <div class="vcard">
        <img class="vc-th" src="${v.thumbnail||'/assets/placeholder.png'}" onerror="this.src='/assets/placeholder.png'" />
        <div class="vc-inf"><div class="vc-ti">${v.title||'—'}</div><div class="vc-sk">${v.sku||''}</div></div>
        <div class="vc-r"><div class="vc-q">${v.quantidade} un</div><div class="vc-v">R$ ${(v.receita||0).toFixed(2)}</div></div>
      </div>`).join('');
    renderInsights(S.estoque,S.vendas);
  }catch(e){document.getElementById('full-vend-body').innerHTML=`<div class="loading-bar" style="color:var(--accent-red);">⚠️ ${e.message}</div>`;}
}

function renderInsights(estoque,vendas){
  const top5q=[...vendas].sort((a,b)=>(b.quantidade||0)-(a.quantidade||0)).slice(0,5);
  const top5r=[...vendas].sort((a,b)=>(b.receita||0)-(a.receita||0)).slice(0,5);
  const crit=estoque.filter(i=>i.available_quantity<=3).slice(0,5);
  const rk=(items,vf)=>items.map((it,i)=>`<div class="ri"><span class="ri-pos">${i+1}</span><span class="ri-nm" title="${it.title||''}">${it.title||'—'}</span><span class="ri-vl">${vf(it)}</span></div>`).join('');
  document.getElementById('full-ins-body').innerHTML=`
    <div class="ig-card"><div class="ig-title">🏆 Mais Vendidos (qtd)</div>${top5q.length?rk(top5q,i=>`${i.quantidade} un`):'<div style="font-size:12px;color:var(--text-muted);padding:8px 0;">Sem dados</div>'}</div>
    <div class="ig-card"><div class="ig-title">💰 Maior Receita</div>${top5r.length?rk(top5r,i=>`R$ ${(i.receita||0).toFixed(0)}`):'<div style="font-size:12px;color:var(--text-muted);padding:8px 0;">Sem dados</div>'}</div>
    <div class="ig-card"><div class="ig-title">⚠️ Estoque Crítico no CD</div>${crit.length?rk(crit,i=>`${i.available_quantity} un`):'<div style="font-size:12px;color:var(--accent-green);padding:8px 0;">✓ Todos OK</div>'}</div>`;
}

// ── SCANNER ──────────────────────────────────
async function processBaixa(){
  const inp=document.getElementById('scan-inp');
  const code=(inp.value||'').trim();if(!code)return;
  inp.classList.remove('ok','er');
  const res=document.getElementById('scan-res');
  res.className='scan-res show';res.innerHTML='<span class="spin" style="color:var(--text-muted);">⟳</span> Processando…';
  try{
    const r=await fetch('/api/ml/scan-baixa',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({code})});
    const d=await r.json();
    if(r.ok&&d.ok){
      inp.classList.add('ok');res.className='scan-res show sr-ok';
      res.innerHTML=`<div class="sr-t">✅ Baixa registrada!</div><div class="sr-s">#${d.orderId} · ${d.buyer||'—'} · ${d.tracking||code}</div>`;
      const o=S.orders.find(x=>String(x.id)===String(d.orderId));
      if(o){o._localStatus='enviado';updateCnt();renderList();}
      addLog({code,buyer:d.buyer,status:'ok',orderId:d.orderId});
      toast('Baixa registrada!','ok');
    }else if(d.alreadyDone){
      inp.classList.add('ok');res.className='scan-res show sr-wa';
      res.innerHTML=`<div class="sr-t">⚠️ Já baixado</div><div class="sr-s">#${d.orderId} já enviado</div>`;
      addLog({code,buyer:d.buyer,status:'wa',orderId:d.orderId});
    }else throw new Error(d.error||'Não encontrado');
  }catch(e){
    inp.classList.add('er');res.className='scan-res show sr-er';
    res.innerHTML=`<div class="sr-t">❌ ${e.message}</div>`;
    addLog({code,buyer:null,status:'er',orderId:null});toast(e.message,'er');
  }
  setTimeout(()=>{inp.value='';inp.classList.remove('ok','er');inp.focus();},1200);
}

function addLog(b){
  const t=new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  S.baixas.unshift({...b,time:t});
  document.getElementById('baixas-list').innerHTML=S.baixas.slice(0,30).map(x=>`
    <div class="log-item">
      <div class="log-dot ${x.status==='ok'?'ld-ok':x.status==='wa'?'ld-wa':'ld-er'}"></div>
      <div class="log-code">${x.code}</div>
      <div class="log-by">${x.orderId?`#${x.orderId} ${x.buyer||''}`:x.buyer||'Não encontrado'}</div>
      <div class="log-tm">${x.time}</div>
    </div>`).join('');
}

// ── RECLAMAÇÕES ──────────────────────────────
async function loadReclamacoes(){
  document.getElementById('reclam-list').innerHTML='<div class="loading-bar"><span class="spin">⟳</span></div>';
  try{
    const r=await fetch('/api/ml/claims');const d=await r.json();
    if(!r.ok)throw new Error(d.error||'Erro');
    S.reclam=d.claims||[];
    document.getElementById('badge-reclam').textContent=S.reclam.length||'—';
    document.getElementById('reclam-sum').textContent=`${S.reclam.length} ativa(s)`;
    if(S.reclam.length)document.getElementById('tab-reclam').classList.add('warn-tab');
    if(!S.reclam.length){document.getElementById('reclam-list').innerHTML='<div class="empty-state"><div class="empty-icon">✅</div><div class="empty-msg">Nenhuma reclamação aberta</div></div>';return;}
    const SM={opened:'Aberta',in_mediation:'Em Mediação',closed:'Encerrada',resolved:'Resolvida'};
    const SC={opened:'bs-can',in_mediation:'bs-imp',closed:'bs-env',resolved:'bs-env'};
    const RM={ITEM_NOT_RECEIVED:'📦 Não recebido',ITEM_NOT_AS_DESCRIBED:'🔎 Diferente do anúncio',DAMAGED_ITEM:'💥 Danificado',CANCEL_PURCHASE:'↩️ Cancelamento'};
    document.getElementById('reclam-list').innerHTML=S.reclam.map((c,i)=>`
      <div class="rec-card">
        <div class="rec-hdr" onclick="document.getElementById('rb${i}').classList.toggle('open')">
          <div>
            <div style="font-size:10px;font-family:'Space Mono',monospace;color:var(--text-muted);">Caso #${c.id||'—'} · Pedido #${c.resource_id||'—'}</div>
            <div style="font-size:13px;font-weight:700;margin-top:2px;">${c.buyer_id||'—'}</div>
            <div style="font-size:11px;color:var(--text-secondary);margin-top:2px;">${RM[c.reason?.id]||c.reason?.id||'—'}</div>
          </div>
          <span class="bs ${SC[c.status]||'bs-imp'}">${SM[c.status]||c.status}</span>
          <span style="font-size:10px;color:var(--text-muted);">${c.date_created?new Date(c.date_created).toLocaleDateString('pt-BR'):'—'}</span>
        </div>
        <div class="rec-body" id="rb${i}">
          <div class="rec-det"><strong>Motivo:</strong> ${RM[c.reason?.id]||'—'}<br><strong>Status:</strong> ${SM[c.status]||c.status}</div>
          <div class="rec-ft">
            <a href="https://www.mercadolivre.com.br/vendas/reclamacoes/${c.id}" target="_blank" class="btn btn-def btn-sm">↗ Abrir no ML</a>
            <span style="font-size:10px;color:var(--text-muted);">Responda no ML para resolução mais rápida</span>
          </div>
        </div>
      </div>`).join('');
  }catch(e){document.getElementById('reclam-list').innerHTML=`<div class="loading-bar" style="color:var(--accent-red);">⚠️ ${e.message}</div>`;}
}

// ── TOAST ────────────────────────────────────
function toast(msg,t='in'){
  const c=document.getElementById('toasts');const el=document.createElement('div');
  el.className=`toast t-${t}`;el.textContent=msg;c.appendChild(el);
  setTimeout(()=>el.remove(),3500);
}
</script>
