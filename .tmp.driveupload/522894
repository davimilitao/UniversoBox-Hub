              <div class="stab-row">
                <button class="stab active" onclick="filterSt('todos',this)"><span class="stab-n" id="cnt-todos">0</span>Todos</button>
                <button class="stab" onclick="filterSt('imprimir',this)"><span class="stab-n" id="cnt-imprimir">0</span>Imprimir</button>
                <button class="stab" onclick="filterSt('expedir',this)"><span class="stab-n" id="cnt-expedir">0</span>Expedir</button>
                <button class="stab" onclick="filterSt('enviado',this)"><span class="stab-n" id="cnt-enviado">0</span>Enviados</button>
              </div>
              <input type="text" class="search-input" placeholder="Buscar apelido ou produto…" id="ped-search" oninput="renderList()" />
            </div>
            <div class="ped-list" id="ped-list"><div class="loading-bar"><span class="spin">⟳</span> Buscando…</div></div>
          </div>
          <div class="ped-detail" id="ped-detail">
            <div class="empty-state"><div class="empty-icon">📦</div><div class="empty-msg">Selecione um pedido</div><div class="empty-sub">Clique em um pedido à esquerda</div></div>
          </div>
        </div>
      </div>

      <!-- GESTÃO FULL -->
      <div class="ml-panel" id="panel-full">
        <div class="full-layout">
          <div class="full-sub-tabs">
            <button class="fstab active" onclick="showFull('estoque',this)">📦 Estoque CD</button>
            <button class="fstab" onclick="showFull('vendas',this)">📊 Vendas</button>
            <button class="fstab" onclick="showFull('insights',this)">🧠 Inteligência</button>
          </div>
          <div class="full-panel active" id="full-estoque">
            <div class="kpi-grid" id="full-kpis"><div class="loading-bar"><span class="spin">⟳</span></div></div>
