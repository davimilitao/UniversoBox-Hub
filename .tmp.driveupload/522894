<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>ML Dashboard — Expedição Pro</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/erp.css" />
  <link rel="stylesheet" href="/erp-custom.css">
  <script src="/auth-guard.js"></script>
  <style>
    .ml-layout{display:flex;flex-direction:column;flex:1;overflow:hidden;min-height:0;}
    .ml-topbar{padding:10px 20px;border-bottom:1px solid var(--border-subtle);display:flex;align-items:center;gap:12px;flex-shrink:0;background:var(--depth-3);flex-wrap:wrap;}
    .corte-box{display:flex;flex-direction:column;align-items:center;padding:5px 12px;background:rgba(245,200,66,.07);border:1px solid rgba(245,200,66,.2);border-radius:var(--r-md);}
    .corte-time{font-family:'Space Mono',monospace;font-size:18px;font-weight:700;color:var(--accent-yellow);line-height:1;}
    .corte-lbl{font-size:8px;font-weight:700;text-transform:uppercase;color:var(--text-muted);margin-top:2px;}
    .corte-cd{font-size:10px;color:var(--accent-orange);font-weight:700;margin-top:1px;}
    .lchip{display:flex;flex-direction:column;align-items:center;padding:5px 10px;border-radius:var(--r-md);border:1px solid var(--border-default);background:var(--depth-4);min-width:48px;}
    .lchip-val{font-family:'Space Mono',monospace;font-size:16px;font-weight:700;line-height:1;}
    .lchip-lbl{font-size:8px;font-weight:700;text-transform:uppercase;color:var(--text-muted);margin-top:2px;}
    .lchip.ag .lchip-val{color:var(--accent-yellow);}
    .lchip.fx .lchip-val{color:var(--accent-blue);}
    .lchip.fu .lchip-val{color:var(--accent-green);}
    .lchip.co .lchip-val{color:#a78bfa;}
    .auth-bar{display:flex;align-items:center;gap:8px;padding:5px 12px;background:rgba(59,130,246,.07);border:1px solid rgba(59,130,246,.2);border-radius:var(--r-md);cursor:pointer;transition:background .15s;}
    .auth-bar:hover{background:rgba(59,130,246,.12);}
    .auth-code{font-family:'Space Mono',monospace;font-size:14px;font-weight:700;color:var(--accent-blue);letter-spacing:.08em;}
    .auth-lbl{font-size:9px;color:var(--text-muted);display:block;}
    .ml-tabs{display:flex;gap:2px;padding:8px 20px 0;border-bottom:1px solid var(--border-subtle);flex-shrink:0;background:var(--depth-2);}
    .ml-tab{padding:8px 14px;font-family:var(--font-body);font-size:12px;font-weight:700;color:var(--text-muted);background:transparent;border:none;border-bottom:2px solid transparent;cursor:pointer;transition:all .15s;border-radius:var(--r-sm) var(--r-sm) 0 0;display:flex;align-items:center;gap:5px;}
    .ml-tab:hover{color:var(--text-primary);background:var(--depth-3);}
    .ml-tab.active{color:var(--accent-blue);border-bottom-color:var(--accent-blue);background:var(--depth-3);}
    .ml-tab.warn-tab{color:var(--accent-orange);}
    .tab-badge{font-size:9px;font-weight:800;padding:1px 5px;min-width:18px;text-align:center;background:rgba(59,130,246,.15);color:var(--accent-blue);border-radius:var(--r-full);}
    .tab-badge.red{background:rgba(239,68,68,.15);color:var(--accent-red);}
    .tab-badge.grn{background:rgba(16,185,129,.15);color:var(--accent-green);}
    .ml-panels{flex:1;overflow:hidden;display:flex;flex-direction:column;min-height:0;}
    .ml-panel{display:none;flex:1;overflow:hidden;flex-direction:column;min-height:0;}
    .ml-panel.active{display:flex;}

    /* PEDIDOS */
    .ped-layout{display:grid;grid-template-columns:300px 1fr;flex:1;overflow:hidden;min-height:0;}
    .ped-sidebar{border-right:1px solid var(--border-subtle);display:flex;flex-direction:column;overflow:hidden;}
    .ped-toolbar{padding:10px 12px;border-bottom:1px solid var(--border-subtle);display:flex;flex-direction:column;gap:7px;flex-shrink:0;}
    .ped-list{flex:1;overflow-y:auto;padding:8px;}
    .ped-list::-webkit-scrollbar{width:3px;}
    .ped-list::-webkit-scrollbar-thumb{background:var(--depth-5);border-radius:2px;}
    .log-tabs{display:flex;gap:3px;flex-wrap:wrap;}
    .ltab{padding:3px 10px;font-size:10px;font-weight:700;border-radius:var(--r-full);border:1px solid var(--border-subtle);background:var(--depth-4);color:var(--text-muted);cursor:pointer;transition:all .15s;}
    .ltab:hover{color:var(--text-primary);}
    .ltab.a-all{background:var(--depth-5);color:var(--text-primary);border-color:var(--border-strong);}
    .ltab.a-ag{background:rgba(245,200,66,.12);color:var(--accent-yellow);border-color:rgba(245,200,66,.3);}
    .ltab.a-fx{background:rgba(59,130,246,.12);color:var(--accent-blue);border-color:rgba(59,130,246,.3);}
    .stab-row{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;}
    .stab{padding:4px 2px;background:var(--depth-4);border:1px solid var(--border-subtle);border-radius:var(--r-sm);cursor:pointer;font-size:10px;font-weight:700;color:var(--text-muted);text-align:center;transition:all .15s;display:flex;flex-direction:column;align-items:center;gap:1px;}
    .stab:hover{background:var(--depth-5);color:var(--text-primary);}
    .stab.active{background:rgba(245,200,66,.1);color:var(--accent-yellow);border-color:rgba(245,200,66,.25);}
    .stab-n{font-family:'Space Mono',monospace;font-size:14px;font-weight:700;line-height:1;}
    .search-input{width:100%;background:var(--depth-4);border:1px solid var(--border-subtle);border-radius:var(--r-sm);padding:7px 10px;color:var(--text-primary);font-family:var(--font-body);font-size:12px;outline:none;box-sizing:border-box;}
    .search-input:focus{border-color:var(--accent-blue);}

    /* ORDER CARD */
    .ocard{background:var(--depth-3);border:1px solid var(--border-default);border-left:3px solid transparent;border-radius:var(--r-md);padding:9px 11px;cursor:pointer;transition:all .15s;margin-bottom:5px;display:block;width:100%;text-align:left;color:inherit;}
    .ocard:hover{background:var(--depth-4);border-color:var(--border-strong);}
    .ocard.sel{border-color:var(--accent-yellow);background:rgba(245,200,66,.05);}
    .ocard[data-log="agency"]{border-left-color:var(--accent-yellow);}
    .ocard[data-log="flex"]{border-left-color:var(--accent-blue);}
    .ocard[data-log="pickup"]{border-left-color:#a78bfa;}
    .ocard-top{display:flex;align-items:center;justify-content:space-between;gap:6px;margin-bottom:3px;}
    .ocard-nick{font-size:13px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .ocard-meta{font-size:10px;color:var(--text-muted);display:flex;gap:8px;margin-top:2px;flex-wrap:wrap;}
    .ocard-prod{font-size:10px;color:var(--text-muted);margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .bl{font-size:9px;font-weight:800;padding:2px 6px;border-radius:var(--r-full);}
    .bl-ag{background:rgba(245,200,66,.2);color:#b8950a;}
    .bl-fx{background:rgba(59,130,246,.15);color:var(--accent-blue);}
    .bl-co{background:rgba(139,92,246,.15);color:#a78bfa;}
    .bs{font-size:9px;font-weight:800;padding:2px 6px;border-radius:var(--r-full);}
    .bs-imp{background:rgba(249,115,22,.15);color:var(--accent-orange);border:1px solid rgba(249,115,22,.2);}
    .bs-exp{background:rgba(59,130,246,.15);color:var(--accent-blue);border:1px solid rgba(59,130,246,.2);}
    .bs-env{background:rgba(16,185,129,.15);color:var(--accent-green);border:1px solid rgba(16,185,129,.2);}
    .bs-can{background:rgba(239,68,68,.15);color:var(--accent-red);border:1px solid rgba(239,68,68,.2);}

    /* DETALHE */
    .ped-detail{flex:1;display:flex;flex-direction:column;overflow:hidden;background:var(--depth-2);}
    .pd-hdr{padding:14px 20px;border-bottom:1px solid var(--border-subtle);display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-shrink:0;background:var(--depth-3);}
    .pd-nick{font-size:16px;font-weight:800;margin-bottom:2px;}
    .pd-meta2{display:flex;gap:6px;flex-wrap:wrap;align-items:center;margin-top:4px;}
    .pd-acts{display:flex;gap:6px;align-items:center;flex-shrink:0;flex-wrap:wrap;}
    .pd-items{flex:1;overflow-y:auto;padding:14px 20px;display:flex;flex-direction:column;gap:8px;}
    .pd-items::-webkit-scrollbar{width:4px;}
    .pd-foot{padding:10px 20px;border-top:1px solid var(--border-subtle);display:flex;align-items:center;gap:10px;flex-shrink:0;background:var(--depth-3);}
    .ml-irow{background:var(--depth-3);border:1px solid var(--border-default);border-radius:var(--r-md);padding:10px 14px;display:grid;grid-template-columns:auto 1fr auto;gap:12px;align-items:center;}
    .ml-ith{width:44px;height:44px;border-radius:var(--r-sm);object-fit:cover;background:var(--depth-4);border:1px solid var(--border-subtle);}
    .ml-itit{font-size:13px;font-weight:600;margin-bottom:3px;line-height:1.3;}
    .ml-isku{font-family:'Space Mono',monospace;font-size:10px;color:var(--accent-blue);}
    .ml-iqty{font-family:'Space Mono',monospace;font-size:16px;font-weight:700;text-align:right;}
    .ml-iprc{font-size:11px;color:var(--text-muted);text-align:right;}

    /* BTNs */
    .btn{padding:8px 14px;border-radius:var(--r-sm);border:1px solid var(--border-default);font-family:var(--font-body);font-size:12px;font-weight:700;cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:5px;}
    .btn:disabled{opacity:.4;cursor:not-allowed;}
    .btn-def{background:var(--depth-4);color:var(--text-secondary);}
    .btn-def:hover:not(:disabled){background:var(--depth-5);color:var(--text-primary);}
    .btn-pri{background:var(--accent-blue);color:#fff;border-color:transparent;}
    .btn-pri:hover:not(:disabled){filter:brightness(1.1);}
    .btn-yel{background:var(--accent-yellow);color:#000;border-color:transparent;}
    .btn-yel:hover:not(:disabled){filter:brightness(1.1);}
    .btn-grn{background:var(--accent-green);color:#fff;border-color:transparent;}
    .btn-grn:hover:not(:disabled){filter:brightness(1.1);}
    .btn-sm{padding:5px 10px;font-size:11px;}

    /* FULL */
    .full-layout{flex:1;display:flex;flex-direction:column;overflow:hidden;}
    .full-sub-tabs{display:flex;gap:2px;padding:10px 20px 0;border-bottom:1px solid var(--border-subtle);flex-shrink:0;background:var(--depth-3);}
    .fstab{padding:7px 16px;font-size:12px;font-weight:700;color:var(--text-muted);background:transparent;border:none;border-bottom:2px solid transparent;cursor:pointer;transition:all .15s;}
    .fstab.active{color:var(--accent-green);border-bottom-color:var(--accent-green);}
    .full-panel{display:none;flex:1;overflow-y:auto;padding:18px 20px;}
    .full-panel.active{display:block;}
    .kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:18px;}
    .kpi-card{background:var(--depth-3);border:1px solid var(--border-default);border-radius:var(--r-md);padding:14px 16px;}
    .kpi-val{font-family:'Space Mono',monospace;font-size:24px;font-weight:700;line-height:1;}
    .kpi-lbl{font-size:10px;font-weight:700;color:var(--text-muted);text-transform:uppercase;margin-top:4px;letter-spacing:.04em;}
    .kpi-sub{font-size:11px;color:var(--text-secondary);margin-top:2px;}
    .kv-g{color:var(--accent-green);} .kv-y{color:var(--accent-yellow);} .kv-r{color:var(--accent-red);} .kv-b{color:var(--accent-blue);}
    .sec-title{font-size:10px;font-weight:800;text-transform:uppercase;color:var(--text-muted);letter-spacing:.07em;padding:6px 0 4px;border-bottom:1px solid var(--border-subtle);margin-bottom:10px;}
    .ftable{width:100%;border-collapse:collapse;}
    .ftable th{font-size:10px;font-weight:700;text-transform:uppercase;color:var(--text-muted);letter-spacing:.04em;padding:6px 10px;text-align:left;border-bottom:1px solid var(--border-subtle);}
    .ftable td{padding:9px 10px;border-bottom:1px solid var(--border-subtle);font-size:12px;vertical-align:middle;}
    .ftable tr:hover td{background:var(--depth-4);}
    .sbar-w{width:80px;height:6px;background:var(--depth-5);border-radius:3px;overflow:hidden;}
    .sbar{height:100%;border-radius:3px;transition:width .3s;}
    .sb-ok{background:var(--accent-green);} .sb-lo{background:var(--accent-yellow);} .sb-cr{background:var(--accent-red);}
    .atag{font-size:9px;font-weight:800;padding:2px 6px;border-radius:var(--r-full);border:1px solid;}
    .at-ok{background:rgba(16,185,129,.1);color:var(--accent-green);border-color:rgba(16,185,129,.2);}
    .at-lo{background:rgba(245,200,66,.1);color:var(--accent-yellow);border-color:rgba(245,200,66,.2);}
    .at-cr{background:rgba(239,68,68,.1);color:var(--accent-red);border-color:rgba(239,68,68,.2);}
    .vf-row{display:flex;gap:6px;margin-bottom:14px;align-items:center;flex-wrap:wrap;}
    .vf-btn{padding:4px 10px;font-size:11px;font-weight:700;border-radius:var(--r-full);border:1px solid var(--border-default);background:var(--depth-4);color:var(--text-muted);cursor:pointer;}
    .vf-btn.active{background:var(--accent-green);color:#fff;border-color:transparent;}
    .vcard{background:var(--depth-3);border:1px solid var(--border-default);border-radius:var(--r-md);padding:10px 14px;margin-bottom:8px;display:flex;align-items:center;gap:12px;}
    .vc-th{width:40px;height:40px;border-radius:var(--r-sm);object-fit:cover;background:var(--depth-4);flex-shrink:0;}
    .vc-inf{flex:1;min-width:0;}
    .vc-ti{font-size:12px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .vc-sk{font-family:'Space Mono',monospace;font-size:10px;color:var(--accent-blue);margin-top:2px;}
    .vc-r{text-align:right;flex-shrink:0;}
    .vc-q{font-family:'Space Mono',monospace;font-size:16px;font-weight:700;color:var(--accent-green);}
    .vc-v{font-size:11px;color:var(--text-muted);}
    .ig-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:12px;}
    .ig-card{background:var(--depth-3);border:1px solid var(--border-default);border-radius:var(--r-md);padding:16px;}
    .ig-title{font-size:11px;font-weight:700;text-transform:uppercase;color:var(--text-muted);letter-spacing:.04em;margin-bottom:12px;}
    .ri{display:flex;align-items:center;gap:10px;padding:6px 0;border-bottom:1px solid var(--border-subtle);}
    .ri:last-child{border-bottom:none;}
    .ri-pos{font-family:'Space Mono',monospace;font-size:12px;font-weight:700;color:var(--text-muted);width:18px;text-align:right;flex-shrink:0;}
    .ri-nm{flex:1;font-size:12px;font-weight:600;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .ri-vl{font-family:'Space Mono',monospace;font-size:12px;font-weight:700;flex-shrink:0;}

    /* SCANNER */
    .scan-layout{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;padding:28px 20px;overflow-y:auto;gap:18px;}
    .scan-card{width:100%;max-width:540px;background:var(--depth-3);border:1px solid var(--border-default);border-radius:var(--r-lg);overflow:hidden;}
    .scan-hdr{padding:14px 20px;border-bottom:1px solid var(--border-subtle);display:flex;align-items:center;gap:12px;}
    .scan-body{padding:20px;}
    .scan-wrap{display:flex;gap:8px;}
    .scan-inp{flex:1;background:var(--depth-4);border:2px solid var(--border-default);border-radius:var(--r-md);padding:12px 16px;font-family:'Space Mono',monospace;font-size:18px;font-weight:700;color:var(--text-primary);outline:none;transition:border-color .15s;letter-spacing:.04em;}
    .scan-inp:focus{border-color:var(--accent-blue);}
    .scan-inp.ok{border-color:var(--accent-green);}
    .scan-inp.er{border-color:var(--accent-red);}
    .scan-res{margin-top:14px;padding:12px 14px;border-radius:var(--r-md);border:1px solid var(--border-default);display:none;}
    .scan-res.show{display:block;}
    .sr-ok{background:rgba(16,185,129,.07);border-color:rgba(16,185,129,.2);}
    .sr-er{background:rgba(239,68,68,.07);border-color:rgba(239,68,68,.2);}
    .sr-wa{background:rgba(249,115,22,.07);border-color:rgba(249,115,22,.2);}
    .sr-t{font-size:13px;font-weight:700;margin-bottom:3px;}
    .sr-s{font-size:11px;color:var(--text-secondary);}
    .sr-ok .sr-t{color:var(--accent-green);} .sr-er .sr-t{color:var(--accent-red);} .sr-wa .sr-t{color:var(--accent-orange);}
    .log-list{width:100%;max-width:540px;}
    .log-tit{font-size:10px;font-weight:700;text-transform:uppercase;color:var(--text-muted);letter-spacing:.06em;margin-bottom:7px;}
    .log-item{display:flex;align-items:center;gap:10px;padding:7px 10px;background:var(--depth-3);border:1px solid var(--border-default);border-radius:var(--r-sm);margin-bottom:4px;font-size:12px;}
    .log-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
    .ld-ok{background:var(--accent-green);} .ld-er{background:var(--accent-red);} .ld-wa{background:var(--accent-yellow);}
    .log-code{font-family:'Space Mono',monospace;font-size:11px;font-weight:700;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .log-by{font-size:11px;color:var(--text-muted);flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .log-tm{font-size:10px;color:var(--text-muted);flex-shrink:0;}

    /* RECLAMAÇÕES */
    .rec-layout{flex:1;overflow-y:auto;padding:16px 20px;display:flex;flex-direction:column;gap:10px;}
    .rec-card{background:var(--depth-3);border:1px solid var(--border-default);border-left:3px solid var(--accent-red);border-radius:var(--r-md);overflow:hidden;}
    .rec-hdr{display:grid;grid-template-columns:1fr auto auto;align-items:center;gap:12px;padding:11px 15px;cursor:pointer;}
    .rec-body{display:none;flex-direction:column;border-top:1px solid var(--border-subtle);}
    .rec-body.open{display:flex;}
    .rec-det{padding:12px 15px;font-size:12px;color:var(--text-secondary);line-height:1.6;background:var(--depth-4);}
    .rec-ft{display:flex;align-items:center;justify-content:space-between;gap:8px;padding:9px 15px;border-top:1px solid var(--border-subtle);}

    /* GERAL */
    @keyframes spin{to{transform:rotate(360deg)}}
    .spin{display:inline-block;animation:spin .7s linear infinite;}
    .loading-bar{display:flex;align-items:center;gap:8px;padding:20px;justify-content:center;color:var(--text-muted);font-size:12px;}
    .empty-state{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:var(--text-muted);text-align:center;padding:40px;}
    .empty-icon{font-size:36px;opacity:.3;}
    .empty-msg{font-size:14px;font-weight:600;}
    .empty-sub{font-size:12px;opacity:.6;}
    .toast-cont{position:fixed;bottom:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:7px;pointer-events:none;}
    .toast{padding:9px 14px;border-radius:var(--r-md);font-size:12px;font-weight:700;box-shadow:0 4px 16px rgba(0,0,0,.4);pointer-events:all;animation:tin .2s ease;max-width:300px;}
    .t-ok{background:var(--accent-green);color:#fff;} .t-er{background:var(--accent-red);color:#fff;} .t-in{background:var(--accent-blue);color:#fff;}
    @keyframes tin{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
  </style>
</head>
<body>
<div class="erp-layout">
  <div id="sidebar-placeholder"></div>
  <main class="erp-main" style="overflow:hidden;display:flex;flex-direction:column;height:calc(100vh - 0px);">

  <div style="padding:12px 20px 8px;border-bottom:1px solid var(--border-subtle);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-shrink:0;">
    <div>
      <h1 style="font-size:20px;font-weight:800;display:flex;align-items:center;gap:8px;margin:0;">
        🛒 ML Dashboard
        <span id="conn-dot" style="width:7px;height:7px;border-radius:50%;background:var(--text-muted);display:inline-block;"></span>
      </h1>
      <p style="font-size:11px;color:var(--text-muted);margin:2px 0 0;">Expedição do dia · Mercado Livre</p>
    </div>
    <div style="display:flex;gap:8px;align-items:center;">
      <button class="btn btn-def btn-sm" onclick="refreshAll()">↻ Atualizar</button>
      <span id="last-up" style="font-size:10px;color:var(--text-muted);"></span>
    </div>
  </div>

  <div class="ml-layout">
    <div class="ml-topbar" id="topbar">
      <div class="loading-bar" style="padding:8px;"><span class="spin">⟳</span> Carregando…</div>
    </div>

    <div class="ml-tabs">
      <button class="ml-tab active" onclick="showTab('pedidos')" id="tab-pedidos">
        📦 Agência &amp; Flex <span class="tab-badge" id="badge-pedidos">—</span>
      </button>
      <button class="ml-tab" onclick="showTab('full')" id="tab-full">
        ⚡ Gestão Full <span class="tab-badge grn" id="badge-full">—</span>
      </button>
      <button class="ml-tab" onclick="showTab('scanner')" id="tab-scanner">
        📷 Baixa / Scanner
      </button>
      <button class="ml-tab" onclick="showTab('reclamacoes')" id="tab-reclam">
        ⚠️ Reclamações <span class="tab-badge red" id="badge-reclam">—</span>
      </button>
    </div>

    <div class="ml-panels">

      <!-- PEDIDOS: AGÊNCIA + FLEX -->
      <div class="ml-panel active" id="panel-pedidos">
        <div class="ped-layout">
          <div class="ped-sidebar">
            <div class="ped-toolbar">
              <div class="log-tabs">
                <button class="ltab a-all" onclick="filterLog('all',this)">Todos</button>
