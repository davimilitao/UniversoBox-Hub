          <span style="font-size:13px;font-weight:700;">Reclamações Abertas</span>
          <span id="reclam-sum" style="font-size:11px;color:var(--text-muted);"></span>
          <button class="btn btn-def btn-sm" onclick="loadReclamacoes()" style="margin-left:auto;">↻</button>
        </div>
        <div class="rec-layout" id="reclam-list"><div class="loading-bar"><span class="spin">⟳</span></div></div>
